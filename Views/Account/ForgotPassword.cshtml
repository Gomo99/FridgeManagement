@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-card">
    <a asp-action="Login" asp-controller="Account"
       class="d-inline-flex align-items-center gap-2 mb-3"
       style="font-size:.82rem;color:var(--muted);text-decoration:none">
        <i class="fas fa-arrow-left"></i> Back to Sign In
    </a>

    <div class="auth-title">Forgot Password?</div>
    <div class="auth-subtitle">Enter your registered email and we'll send you a 6-digit reset PIN</div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-ice-success mb-3">
            <i class="fas fa-envelope-circle-check"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-ice-danger mb-3">
            <i class="fas fa-circle-xmark"></i> @TempData["ErrorMessage"]
        </div>
    }

    <form asp-action="ForgotPassword" asp-controller="Account" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-4">
            <label for="email" class="form-label">
                <i class="fas fa-envelope me-1"></i> Email Address
            </label>
            <input type="email" id="email" name="email" class="form-control"
                   placeholder="your@email.com" required autofocus />
        </div>

        <button type="submit" class="btn-primary-ice">
            <i class="fas fa-paper-plane me-2"></i>Send Reset PIN
        </button>
    </form>

    <div class="divider">Note</div>
    <div class="d-flex align-items-start gap-2 p-3 rounded"
         style="background:rgba(56,189,248,.06);border:1px solid rgba(56,189,248,.12);font-size:.8rem;color:var(--muted)">
        <i class="fas fa-circle-info mt-1" style="color:var(--accent);flex-shrink:0"></i>
        <span>The reset PIN expires in <strong style="color:var(--text)">5 minutes</strong>.
            If you don't receive an email, check your spam folder or contact your administrator.</span>
    </div>
</div>
