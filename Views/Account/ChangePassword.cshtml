@model FridgeManagement.ViewModel.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="page-header">
    <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a asp-action="ViewProfile">My Profile</a></li><li class="breadcrumb-item active">Change Password</li></ol></nav>
    <h1><i class="fas fa-lock" style="color:var(--accent);margin-right:.5rem"></i>Change Password</h1>
    <p>Update your password to keep your account secure</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-ice-success mb-4"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert-ice-danger mb-4"><i class="fas fa-circle-xmark"></i> @TempData["ErrorMessage"]</div>
        }

        <div class="ice-card">
            <div class="ice-card-header">
                <div class="ice-card-title"><i class="fas fa-key"></i>Update Password</div>
            </div>

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert-ice-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">Current Password</label>
                    <div class="password-toggle">
                        <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="Enter current password" id="curPwd" />
                        <button type="button" class="toggle-btn" onclick="togglePwd('curPwd',this)"><i class="fas fa-eye"></i></button>
                    </div>
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">New Password</label>
                    <div class="password-toggle">
                        <input asp-for="NewPassword" type="password" class="form-control" placeholder="Enter new password" id="newPwd" />
                        <button type="button" class="toggle-btn" onclick="togglePwd('newPwd',this)"><i class="fas fa-eye"></i></button>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                    <div style="display:flex;gap:.3rem;margin-top:.5rem">
                        <div class="sbar" id="sb1"></div><div class="sbar" id="sb2"></div>
                        <div class="sbar" id="sb3"></div><div class="sbar" id="sb4"></div>
                    </div>
                    <div id="sLabel" style="font-size:.75rem;color:var(--muted);margin-top:.2rem"></div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Confirm New Password</label>
                    <div class="password-toggle">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm new password" id="conPwd" />
                        <button type="button" class="toggle-btn" onclick="togglePwd('conPwd',this)"><i class="fas fa-eye"></i></button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    <div id="matchMsg" style="font-size:.75rem;margin-top:.25rem"></div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn-ice">
                        <i class="fas fa-rotate" style="margin-right:.4rem"></i>Update Password
                    </button>
                    <a asp-action="ViewProfile" class="btn-ice-outline">Cancel</a>
                </div>
            </form>
        </div>

        <div class="ice-card mt-3" style="font-size:.825rem;color:var(--muted)">
            <div style="font-weight:700;color:var(--accent);margin-bottom:.6rem"><i class="fas fa-circle-info" style="margin-right:.3rem"></i>Password Requirements</div>
            <div style="display:flex;flex-direction:column;gap:.35rem">
                <div><i class="fas fa-check" style="color:var(--success);margin-right:.4rem;width:14px"></i>At least 8 characters long</div>
                <div><i class="fas fa-check" style="color:var(--success);margin-right:.4rem;width:14px"></i>Include uppercase and lowercase letters</div>
                <div><i class="fas fa-check" style="color:var(--success);margin-right:.4rem;width:14px"></i>At least one number</div>
                <div><i class="fas fa-check" style="color:var(--success);margin-right:.4rem;width:14px"></i>At least one special character (!&#64;#$...)</div>
                <div><i class="fas fa-times" style="color:var(--danger);margin-right:.4rem;width:14px"></i>Cannot be the same as current password</div>
            </div>
        </div>
    </div>
</div>

<style>.sbar{height:4px;flex:1;border-radius:4px;background:var(--border);transition:background .3s;}</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function togglePwd(id, btn) {
            const f = document.getElementById(id), i = btn.querySelector('i');
            f.type = f.type === 'password' ? 'text' : 'password';
            i.classList.toggle('fa-eye'); i.classList.toggle('fa-eye-slash');
        }
        document.getElementById('newPwd').addEventListener('input', function () {
            const v = this.value; let s = 0;
            if (v.length >= 8) s++; if (/[A-Z]/.test(v)) s++;
            if (/[0-9]/.test(v)) s++; if (/[^A-Za-z0-9]/.test(v)) s++;
            const c = ['','#ef4444','#f59e0b','#38bdf8','#22c55e'];
            const l = ['','Weak','Fair','Good','Strong'];
            for (let i = 1; i <= 4; i++) document.getElementById('sb'+i).style.background = i <= s ? c[s] : 'var(--border)';
            const el = document.getElementById('sLabel');
            el.textContent = v.length ? l[s] : ''; el.style.color = c[s];
        });
        document.getElementById('conPwd').addEventListener('input', function () {
            const m = document.getElementById('matchMsg');
            if (this.value === document.getElementById('newPwd').value) {
                m.textContent = '✓ Passwords match'; m.style.color = 'var(--success)';
            } else { m.textContent = '✗ Passwords do not match'; m.style.color = 'var(--danger)'; }
        });
    </script>
}
