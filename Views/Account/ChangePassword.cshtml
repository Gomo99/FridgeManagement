@model FridgeManagement.ViewModel.ChangePasswordViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Change Password";
}

<div class="page-header">
    <h1>Change Password</h1>
    <a asp-action="ViewProfile" class="btn-fms btn-ghost-fms"><i class="fa-solid fa-arrow-left"></i> Back to Profile</a>
</div>

<div class="fms-card" style="max-width:500px; margin:auto;">
    <div class="fms-card-header"><div class="fms-card-title">Update your password</div></div>
    <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="fms-form-group">
            <label asp-for="CurrentPassword" class="fms-label">Current Password</label>
            <input asp-for="CurrentPassword" class="fms-input" type="password" required />
            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
        </div>
        <div class="fms-form-group">
            <label asp-for="NewPassword" class="fms-label">New Password</label>
            <input asp-for="NewPassword" class="fms-input" type="password" required />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>
        <div class="fms-form-group">
            <label asp-for="ConfirmPassword" class="fms-label">Confirm New Password</label>
            <input asp-for="ConfirmPassword" class="fms-input" type="password" required />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
        <button type="submit" class="btn-fms btn-primary-fms">Change Password</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}