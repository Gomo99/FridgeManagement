@model IEnumerable<FridgeManagement.Models.User>
@{
    ViewData["Title"] = "Reactivate Accounts";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
    var userList = Model?.ToList() ?? new List<FridgeManagement.Models.User>();
}

<div class="page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="DashBoard">Dashboard</a></li>
            <li class="breadcrumb-item active">Reactivate Accounts</li>
        </ol>
    </nav>
    <h1><i class="fas fa-user-check" style="color:var(--accent);margin-right:.5rem"></i>Reactivate Accounts</h1>
    <p>Restore access for deactivated user accounts</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-ice-success mb-4"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-ice-danger mb-4"><i class="fas fa-circle-xmark"></i> @TempData["ErrorMessage"]</div>
}

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-icon red"><i class="fas fa-users-slash"></i></div>
            <div>
                <div class="stat-value">@userList.Count</div>
                <div class="stat-label">Inactive Accounts</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-icon yellow"><i class="fas fa-user-tie"></i></div>
            <div>
                <div class="stat-value">@userList.Count(u => u.Role.ToString() != "CUSTOMER")</div>
                <div class="stat-label">Staff Accounts</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-user"></i></div>
            <div>
                <div class="stat-value">@userList.Count(u => u.Role.ToString() == "CUSTOMER")</div>
                <div class="stat-label">Customer Accounts</div>
            </div>
        </div>
    </div>
</div>

<div class="ice-card">
    <div class="ice-card-header">
        <div class="ice-card-title">
            <i class="fas fa-users-slash"></i>Deactivated Users
            <span style="font-size:.85rem;font-family:'Nunito',sans-serif;font-weight:400;color:var(--muted);margin-left:.25rem">
                (@userList.Count total)
            </span>
        </div>
        <!-- Filter by role -->
        <select id="roleFilter" class="form-select" style="width:auto;font-size:.8rem;padding:.35rem .75rem !important">
            <option value="">All Roles</option>
            @foreach (var role in userList.Select(u => u.Role.ToString()).Distinct().OrderBy(r => r))
            {
                <option value="@role">@role.Replace("_", " ")</option>
            }
        </select>
    </div>

    @if (!userList.Any())
    {
        <div style="text-align:center;padding:4rem 1rem;color:var(--muted)">
            <div style="width:80px;height:80px;border-radius:50%;background:rgba(34,197,94,.1);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:2rem;color:var(--success)">
                <i class="fas fa-users-check"></i>
            </div>
            <div style="font-family:'Rajdhani',sans-serif;font-size:1.2rem;color:var(--text);margin-bottom:.4rem">All Clear!</div>
            <div style="font-size:.875rem">No deactivated accounts found in the system</div>
        </div>
    }
    else
    {
        <!-- Search -->
        <div class="mb-3">
            <div style="position:relative">
                <i class="fas fa-search" style="position:absolute;left:.9rem;top:50%;transform:translateY(-50%);color:var(--muted);font-size:.82rem;pointer-events:none"></i>
                <input type="text" id="searchInput" class="form-control" placeholder="Search by name, email or username…" style="padding-left:2.5rem !important">
            </div>
        </div>

        <div style="overflow-x:auto">
            <table class="ice-table" id="userTable">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th style="text-align:right">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in userList)
                    {
                        var initials = (!string.IsNullOrEmpty(user.Name) && !string.IsNullOrEmpty(user.Surname))
                            ? $"{user.Name[0]}{user.Surname[0]}".ToUpper() : "U";
                        <tr data-role="@user.Role">
                            <td>
                                <div style="display:flex;align-items:center;gap:.75rem">
                                    <div style="width:38px;height:38px;border-radius:50%;background:rgba(239,68,68,.14);border:1px solid rgba(239,68,68,.3);display:flex;align-items:center;justify-content:center;font-family:'Rajdhani',sans-serif;font-weight:700;font-size:.85rem;color:#fca5a5;flex-shrink:0">
                                        @initials
                                    </div>
                                    <div>
                                        <div style="font-weight:600;color:var(--text);font-size:.875rem">@user.Name @user.Surname</div>
                                        @if (!string.IsNullOrEmpty(user.Title))
                                        {
                                            <div style="font-size:.72rem;color:var(--muted)">@user.Title</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td style="color:var(--muted);font-size:.85rem">@user.Email</td>
                            <td style="color:var(--muted);font-size:.85rem;font-family:monospace">@user.Username</td>
                            <td>
                                <span class="badge-ice purple">@user.Role.ToString().Replace("_", " ")</span>
                            </td>
                            <td>
                                <span class="badge-ice inactive">
                                    <i class="fas fa-circle-xmark" style="margin-right:.25rem;font-size:.6rem"></i>Inactive
                                </span>
                            </td>
                            <td style="text-align:right">
                                <form asp-action="ReactivateAccount" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn-success-ice"
                                            onclick="return confirm('Reactivate account for @user.Name @user.Surname?')">
                                        <i class="fas fa-user-check" style="margin-right:.35rem"></i>Reactivate
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- No results placeholder -->
        <div id="noResults" style="display:none;text-align:center;padding:2rem;color:var(--muted)">
            <i class="fas fa-magnifying-glass" style="font-size:2rem;margin-bottom:.75rem;display:block;opacity:.4"></i>
            No users match your search
        </div>
    }
</div>

@section Scripts {
    <script>
        function filterTable() {
            const q = (document.getElementById('searchInput')?.value || '').toLowerCase();
            const role = document.getElementById('roleFilter')?.value || '';
            const rows = document.querySelectorAll('#userTable tbody tr');
            let visible = 0;
            rows.forEach(row => {
                const textMatch = !q || row.textContent.toLowerCase().includes(q);
                const roleMatch = !role || row.dataset.role === role;
                const show = textMatch && roleMatch;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            const noRes = document.getElementById('noResults');
            if (noRes) noRes.style.display = visible === 0 ? 'block' : 'none';
        }
        document.getElementById('searchInput')?.addEventListener('input', filterTable);
        document.getElementById('roleFilter')?.addEventListener('change', filterTable);
    </script>
}
