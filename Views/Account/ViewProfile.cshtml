@model FridgeManagement.ViewModel.ViewProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    ViewData["ActivePage"] = "Profile";   // highlights "View Profile" in sidebar (if present)
    Layout = "~/Views/Shared/_Layout.cshtml";

    var initials = (!string.IsNullOrEmpty(Model.Name) && !string.IsNullOrEmpty(Model.Surname))
        ? $"{Model.Name[0]}{Model.Surname[0]}".ToUpper()
        : "U";
    var isActive = Model.UserStatus == "Active";
}

<div class="page-header">
    <div>
        <h1><i class="fa-solid fa-user-circle me-2" style="color:var(--ice);"></i>My Profile</h1>
        <p>View and manage your personal account details</p>
    </div>
</div>

<div class="grid-2" style="align-items:start;">

    <!-- LEFT COLUMN – Avatar & Quick Actions -->
    <div>
        <div class="fms-card text-center" style="margin-bottom:18px;">
            <div style="padding:24px 20px;">
                <div style="width:96px;height:96px;border-radius:50%;
                            background:linear-gradient(135deg, var(--ice), #38bdf8);
                            display:flex;align-items:center;justify-content:center;
                            font-family:'Outfit',sans-serif;font-size:2.4rem;font-weight:700;
                            color:#000;margin:0 auto 1rem;
                            box-shadow:0 0 30px rgba(14,165,233,.25);">
                    @initials
                </div>
                <div style="font-family:'Outfit',sans-serif;font-size:1.35rem;font-weight:700;color:var(--white);">
                    @Model.Title @Model.Name @Model.Surname
                </div>
                <div style="font-size:.85rem;color:var(--muted);margin-bottom:.85rem;">@Model.Email</div>
                <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:1.25rem;">
                    <span class="fms-badge @(isActive ? "green" : "red")">
                        <i class="fa-solid @(isActive ? "fa-circle-check" : "fa-circle-xmark") me-1"></i>@Model.UserStatus
                    </span>
                    <span class="fms-badge purple">@Model.Role?.Replace("_", " ")</span>
                </div>

                <hr style="border-color:var(--border);margin:0 0 1.25rem;">

                <!-- Quick actions -->
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <a asp-action="ChangePassword" class="btn-fms btn-primary-fms w-100 justify-content-center">
                        <i class="fa-solid fa-lock"></i> Change Password
                    </a>
                    <form asp-action="DownloadProfile" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-fms btn-ghost-fms w-100 justify-content-center" style="cursor:pointer;">
                            <i class="fa-solid fa-file-pdf" style="color:#ef4444;"></i> Download Profile PDF
                        </button>
                    </form>
                    <a asp-action="DeleteAccount" class="btn-fms btn-danger-fms w-100 justify-content-center">
                        <i class="fa-solid fa-user-slash"></i> Deactivate Account
                    </a>
                </div>
            </div>
        </div>

        <!-- 2FA Status Card -->
        <div class="fms-card" style="border-color:@(Model.IsTwoFactorEnabled ? "rgba(34,197,94,.25)" : "rgba(245,158,11,.25)");">
            <div style="display:flex;align-items:center;gap:14px;padding:16px;">
                <div style="width:44px;height:44px;border-radius:10px;
                            background:@(Model.IsTwoFactorEnabled ? "rgba(34,197,94,.15)" : "rgba(245,158,11,.15)");
                            display:flex;align-items:center;justify-content:center;
                            font-size:1.2rem;
                            color:@(Model.IsTwoFactorEnabled ? "var(--success)" : "var(--warning)");flex-shrink:0;">
                    <i class="fa-solid @(Model.IsTwoFactorEnabled ? "fa-shield-halved" : "fa-shield-exclamation")"></i>
                </div>
                <div style="flex:1;">
                    <div style="font-size:.85rem;font-weight:700;color:@(Model.IsTwoFactorEnabled ? "#86efac" : "#fcd34d")">
                        2FA @(Model.IsTwoFactorEnabled ? "Enabled" : "Disabled")
                    </div>
                    <div style="font-size:.75rem;color:var(--muted);">
                        @(Model.IsTwoFactorEnabled ? "Account is well protected" : "Enable for extra security")
                    </div>
                </div>
                @if (Model.IsTwoFactorEnabled)
                {
                    <a asp-action="DisableTwoFactor" class="btn-fms btn-sm-fms btn-danger-fms">Disable</a>
                }
                else
                {
                    <a asp-action="SetupTwoFactor" class="btn-fms btn-sm-fms btn-primary-fms">Enable</a>
                }
            </div>
        </div>
    </div>

    <!-- RIGHT COLUMN – Detailed Info & Security -->
    <div>
        <!-- Personal Information -->
        <div class="fms-card" style="margin-bottom:18px;">
            <div class="fms-card-header">
                <div class="fms-card-title"><i class="fa-solid fa-id-card"></i> Personal Information</div>
            </div>
            <div style="padding:16px;display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div>
                    <div class="fms-label">Title</div>
                    <div style="color:var(--white);">@Model.Title</div>
                </div>
                <div>
                    <div class="fms-label">Full Name</div>
                    <div style="color:var(--white);">@Model.Name @Model.Surname</div>
                </div>
                <div>
                    <div class="fms-label">Email</div>
                    <div style="color:var(--white);">@Model.Email</div>
                </div>
                <div>
                    <div class="fms-label">Role</div>
                    <div style="color:var(--white);">@Model.Role?.Replace("_", " ")</div>
                </div>
                <div>
                    <div class="fms-label">Account Status</div>
                    <div style="color:var(--white);">@Model.UserStatus</div>
                </div>
                <div>
                    <div class="fms-label">Two‑Factor</div>
                    <div style="color:var(--white);">
                        @if (Model.IsTwoFactorEnabled)
                        {
                            <span class="fms-badge green"><i class="fa-solid fa-shield-halved"></i> Enabled</span>
                        }
                        else
                        {

                            <span class="fms-badge gray">Not enabled</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Security Settings & Actions -->
        <div class="fms-card" style="margin-bottom:18px;">
            <div class="fms-card-header">
                <div class="fms-card-title"><i class="fa-solid fa-shield-halved"></i> Security Settings</div>
            </div>
            <div style="padding:16px;">
                @if (Model.IsTwoFactorEnabled)
                {
                    <div style="display:flex;align-items:center;gap:16px;padding:12px;background:rgba(34,197,94,.07);border:1px solid rgba(34,197,94,.2);border-radius:8px;margin-bottom:14px;">
                        <i class="fa-solid fa-shield-halved" style="color:var(--success);font-size:1.5rem;flex-shrink:0;"></i>
                        <div style="flex:1;">
                            <div style="font-weight:700;color:#86efac;font-size:.9rem;">Two-Factor Authentication is Active</div>
                            <div style="font-size:.78rem;color:var(--muted);">Each sign-in requires a code from your authenticator app</div>
                        </div>
                        <span class="fms-badge green">ON</span>
                    </div>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;">
                        <a asp-action="ManageDevices" class="btn-fms btn-sm-fms btn-ghost-fms"><i class="fa-solid fa-mobile-screen"></i> Trusted Devices</a>
                        <a asp-action="DisableTwoFactor" class="btn-fms btn-sm-fms btn-danger-fms"><i class="fa-solid fa-shield-xmark"></i> Disable 2FA</a>
                    </div>
                }
                else
                {
                    <div style="display:flex;align-items:center;gap:16px;padding:12px;background:rgba(245,158,11,.07);border:1px solid rgba(245,158,11,.2);border-radius:8px;margin-bottom:14px;">
                        <i class="fa-solid fa-triangle-exclamation" style="color:var(--warning);font-size:1.5rem;flex-shrink:0;"></i>
                        <div style="flex:1;">
                            <div style="font-weight:700;color:#fcd34d;font-size:.9rem;">Two-Factor Authentication is Disabled</div>
                            <div style="font-size:.78rem;color:var(--muted);">Enabling 2FA adds a powerful extra layer of protection</div>
                        </div>
                        <span class="fms-badge amber">OFF</span>
                    </div>
                    <a asp-action="SetupTwoFactor" class="btn-fms btn-primary-fms"><i class="fa-solid fa-shield-halved"></i> Enable 2FA Now</a>
                }
            </div>
        </div>

        <!-- Additional Account Actions -->
        <div class="fms-card">
            <div class="fms-card-header">
                <div class="fms-card-title"><i class="fa-solid fa-clock-rotate-left"></i> Account Actions</div>
            </div>
            <div style="padding:16px;display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                <a asp-action="ManageDevices" class="btn-fms btn-ghost-fms w-100" style="justify-content:flex-start;">
                    <i class="fa-solid fa-laptop-mobile"></i> Trusted Devices
                </a>
                <a asp-action="ChangePassword" class="btn-fms btn-ghost-fms w-100" style="justify-content:flex-start;">
                    <i class="fa-solid fa-key"></i> Change Password
                </a>
            </div>
        </div>
    </div>

</div>