@model FridgeManagement.ViewModel.VerificationCodeLoginViewModel
@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
    ViewData["Title"] = "Two‑Factor Authentication";
}

<div class="auth-card">
    <div class="auth-title">Two‑Factor Code</div>
    <div class="auth-subtitle">Enter the verification code from your authenticator app</div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-ice-success mb-3">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-ice-danger mb-3">
            <i class="fas fa-circle-xmark"></i> @TempData["ErrorMessage"]
        </div>
    }

    <form asp-action="VerificationCodeLogin" asp-controller="Account" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="VerificationCode" class="form-label">
                <i class="fas fa-shield-halved me-1"></i> Verification Code
            </label>
            <input asp-for="VerificationCode" class="form-control" placeholder="· · · · · ·"
                   autocomplete="one-time-code" inputmode="numeric"
                   style="letter-spacing:8px;font-size:1.4rem;text-align:center;font-family:'Rajdhani',sans-serif;font-weight:700" />
            <span asp-validation-for="VerificationCode" class="text-danger d-block mt-1"></span>
        </div>

        <div class="mb-4">
            <div class="form-check">
                <input asp-for="RememberThisDevice" class="form-check-input" id="rememberDevice" />
                <label class="form-check-label" for="rememberDevice">Remember this device for 30 days</label>
            </div>
        </div>

        <button type="submit" class="btn-primary-ice">
            <i class="fas fa-check-circle me-2"></i>Verify
        </button>
    </form>

    <div class="divider">Help</div>
    <div class="d-flex justify-content-between">
        <a asp-action="Login" asp-controller="Account">Back to Login</a>
        <a asp-action="ResendRecoveryCodes" asp-controller="Account">Use Recovery Code</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('[name="VerificationCode"]').addEventListener('input', function() {
            this.value = this.value.replace(/\D/g, '').slice(0, 6);
        });
    </script>
}