@model FridgeManagement.ViewModel.TwoFactorSetupViewModel
@{
    ViewData["Title"] = "Setup Two-Factor Authentication";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="ViewProfile">My Profile</a></li>
            <li class="breadcrumb-item active">Setup 2FA</li>
        </ol>
    </nav>
    <h1><i class="fas fa-shield-halved" style="color:var(--accent);margin-right:.5rem"></i>Setup Two-Factor Authentication</h1>
    <p>Secure your account with an authenticator app — takes about 2 minutes</p>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-ice-danger mb-4"><i class="fas fa-circle-xmark"></i> @TempData["ErrorMessage"]</div>
}

<div class="row g-4 justify-content-center">
    <div class="col-lg-8 col-xl-7">

        <!-- Progress Steps -->
        <div style="display:flex;align-items:center;margin-bottom:2rem">
            @{
                var steps = new[] { ("Install App", "fa-mobile-screen"), ("Scan QR Code", "fa-qrcode"), ("Verify Code", "fa-shield-check") };
            }
            @for (int i = 0; i < steps.Length; i++)
            {
                var (label, icon) = steps[i];
                var done = i < 2;
                var active = i == 2;
                <div style="flex:1;text-align:center">
                    <div style="width:38px;height:38px;border-radius:50%;background:@(done || active ? "linear-gradient(135deg,var(--accent),var(--accent2))" : "var(--card2)");border:2px solid @(done || active ? "var(--accent)" : "var(--border)");display:flex;align-items:center;justify-content:center;margin:0 auto .45rem;color:@(done || active ? "#000" : "var(--muted)");font-size:@(done || active ? ".9rem" : ".85rem")">
                        <i class="fas @icon"></i>
                    </div>
                    <div style="font-size:.72rem;font-weight:600;color:@(done || active ? "var(--accent)" : "var(--muted)")">@label</div>
                </div>
                @if (i < steps.Length - 1)
                {
                    <div style="flex:1;height:2px;background:@(done ? "var(--accent)" : "var(--border)");margin-bottom:1.2rem;max-width:60px"></div>
                }
            }
        </div>

        <!-- STEP 1: Install App -->
        <div class="ice-card mb-4">
            <div class="ice-card-header">
                <div class="ice-card-title">
                    <i class="fas fa-mobile-screen"></i>Step 1 &mdash; Install an Authenticator App
                </div>
                <span class="badge-ice active">Required</span>
            </div>
            <p style="font-size:.875rem;color:var(--muted);margin-bottom:1rem">
                Download one of these free apps on your smartphone. We recommend Google Authenticator.
            </p>
            <div class="row g-2">
                @foreach (var (name, fab, sub, col) in new[]
                {
                    ("Google Authenticator", "fa-google",    "iOS & Android",     "var(--accent)"),
                    ("Microsoft Authenticator","fa-microsoft","iOS & Android",    "#818cf8"),
                    ("Authy",                "fa-shield-halved","Multi-device sync","var(--success)"),
                })
                {
                    <div class="col-sm-4">
                        <div style="padding:.85rem .75rem;background:var(--card2);border:1px solid var(--border);border-radius:8px;text-align:center">
                            <i class="fab @fab" style="font-size:1.6rem;color:@col;margin-bottom:.4rem;display:block"></i>
                            <div style="font-size:.8rem;font-weight:700;color:var(--text)">@name</div>
                            <div style="font-size:.7rem;color:var(--muted)">@sub</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- STEP 2: QR Code -->
        <div class="ice-card mb-4">
            <div class="ice-card-header">
                <div class="ice-card-title">
                    <i class="fas fa-qrcode"></i>Step 2 &mdash; Scan the QR Code
                </div>
                <span class="badge-ice active">Required</span>
            </div>
            <p style="font-size:.875rem;color:var(--muted);margin-bottom:1.25rem">
                Open your authenticator app, tap <strong style="color:var(--text)">"+"</strong> or <strong style="color:var(--text)">"Add Account"</strong>, then scan the QR code below:
            </p>

            <div style="text-align:center;margin-bottom:1.25rem">
                @if (!string.IsNullOrEmpty(Model?.QrCodeImageUrl))
                {
                    <div style="display:inline-block;padding:1.1rem;background:#fff;border-radius:14px;box-shadow:0 0 0 5px rgba(56,189,248,.2),0 0 40px rgba(56,189,248,.1)">
                        <img src="@Model.QrCodeImageUrl" alt="2FA QR Code" style="width:190px;height:190px;display:block" />
                    </div>
                }
                else
                {
                    <div style="width:190px;height:190px;border:2px dashed var(--border);border-radius:12px;display:flex;align-items:center;justify-content:center;margin:0 auto;color:var(--muted);font-size:.8rem">
                        <div style="text-align:center"><i class="fas fa-qrcode" style="font-size:2rem;margin-bottom:.5rem;display:block;opacity:.4"></i>QR code not available</div>
                    </div>
                }
            </div>

            <!-- Manual entry key -->
            <div style="font-size:.8rem;color:var(--muted);text-align:center;margin-bottom:.6rem">
                <i class="fas fa-keyboard" style="margin-right:.3rem;color:var(--accent)"></i>
                Can't scan? Enter this secret key manually in your app:
            </div>
            <div style="background:var(--card2);border:1px solid var(--border);border-radius:8px;padding:.8rem 1rem;display:flex;align-items:center;gap:.75rem">
                <code id="secretKey" style="font-family:monospace;color:var(--accent);font-size:.88rem;letter-spacing:.12rem;word-break:break-all;flex:1">
                    @Model?.ManualEntryKey
                </code>
                <button type="button" onclick="copyKey()" id="copyBtn"
                        class="btn-ice-outline" style="white-space:nowrap;font-size:.75rem;padding:.35rem .8rem;flex-shrink:0">
                    <i class="fas fa-copy"></i>
                </button>
            </div>
        </div>

        <!-- STEP 3: Verify -->
        <div class="ice-card">
            <div class="ice-card-header">
                <div class="ice-card-title">
                    <i class="fas fa-shield-check"></i>Step 3 &mdash; Verify &amp; Activate
                </div>
                <span class="badge-ice pending">Final Step</span>
            </div>
            <p style="font-size:.875rem;color:var(--muted);margin-bottom:1.25rem">
                Enter the 6-digit code now showing in your authenticator app to confirm the setup:
            </p>

            <form asp-action="SetupTwoFactor" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="QrCodeImageUrl" />
                <input type="hidden" asp-for="ManualEntryKey" />

                <div class="mb-4">
                    <label class="form-label" style="display:block;text-align:center;margin-bottom:.75rem">Verification Code</label>

                    <!-- Digit display boxes -->
                    <div style="display:flex;gap:.5rem;justify-content:center;margin-bottom:.5rem">
                        @for (int i = 0; i < 6; i++)
                        {
                            <div class="digit-box" id="db@i"
                                 style="width:46px;height:56px;border:1.5px solid var(--border);border-radius:8px;background:var(--input-bg);display:flex;align-items:center;justify-content:center;font-family:'Rajdhani',sans-serif;font-size:1.5rem;font-weight:700;color:var(--accent);transition:border-color .2s;cursor:text"
                                 onclick="document.getElementById('vc').focus()">
                            </div>
                        }
                    </div>

                    <input asp-for="VerificationCode"
                           id="vc"
                           type="text"
                           maxlength="6"
                           inputmode="numeric"
                           autocomplete="one-time-code"
                           style="opacity:0;position:absolute;width:1px;height:1px;pointer-events:none" />
                    <span asp-validation-for="VerificationCode" class="text-danger d-block text-center mt-1"></span>
                </div>

                <div class="d-flex gap-2 justify-content-between align-items-center">
                    <div style="font-size:.78rem;color:var(--muted)">
                        <i class="fas fa-clock" style="color:var(--accent);margin-right:.3rem"></i>
                        TOTP refreshes every 30 seconds
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="ViewProfile" class="btn-ice-outline">Cancel</a>
                        <button type="submit" class="btn-ice" id="activateBtn" disabled style="opacity:.5">
                            <i class="fas fa-shield-halved" style="margin-right:.4rem"></i>Activate 2FA
                        </button>
                    </div>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const vcInput = document.getElementById('vc');
        const dbBoxes = Array.from({length: 6}, (_, i) => document.getElementById('db' + i));
        const activateBtn = document.getElementById('activateBtn');

        setTimeout(() => vcInput.focus(), 300);

        vcInput.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 6);
            const digits = this.value.split('');
            dbBoxes.forEach((box, i) => {
                box.textContent = digits[i] || '';
                box.style.borderColor = digits[i] ? 'var(--accent)' : 'var(--border)';
            });
            const ready = this.value.length === 6;
            activateBtn.disabled = !ready;
            activateBtn.style.opacity = ready ? '1' : '.5';
        });

        function copyKey() {
            const key = document.getElementById('secretKey').textContent.trim();
            navigator.clipboard.writeText(key).then(() => {
                const btn = document.getElementById('copyBtn');
                btn.innerHTML = '<i class="fas fa-check"></i>';
                btn.style.color = 'var(--success)';
                setTimeout(() => { btn.innerHTML = '<i class="fas fa-copy"></i>'; btn.style.color = ''; }, 2200);
            });
        }
    </script>
}
