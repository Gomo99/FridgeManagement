@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-title">
        <i class="fas fa-shield-halved" style="color:var(--accent);font-size:1.3rem;margin-right:.5rem"></i>Reset Password
    </div>
    <div class="auth-subtitle">Enter the 6-digit PIN sent to your email and choose a new password</div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-ice-success mb-3">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-ice-danger mb-3">
            <i class="fas fa-circle-xmark"></i> @TempData["ErrorMessage"]
        </div>
    }

    <form asp-action="ResetPassword" method="post">
        @Html.AntiForgeryToken()

        <!-- PIN INPUT -->
        <div class="mb-3">
            <label class="form-label">
                <i class="fas fa-hashtag" style="color:var(--accent);margin-right:.35rem"></i>6-Digit Reset PIN
            </label>
            <input type="text"
                   name="pin"
                   id="pinInput"
                   class="form-control"
                   placeholder="0  0  0  0  0  0"
                   maxlength="6"
                   pattern="[0-9]{6}"
                   inputmode="numeric"
                   autocomplete="one-time-code"
                   required
                   style="letter-spacing:.5rem;font-size:1.4rem;text-align:center;font-family:'Rajdhani',sans-serif;font-weight:700;padding:.75rem !important" />
            <div style="font-size:.75rem;color:var(--muted);margin-top:.35rem;display:flex;align-items:center;gap:.35rem">
                <i class="fas fa-clock" style="color:var(--warning)"></i>
                PIN expires in <span id="countdown" style="color:var(--warning);font-weight:700;font-family:'Rajdhani',sans-serif">5:00</span>
            </div>
        </div>

        <!-- NEW PASSWORD -->
        <div class="mb-3">
            <label class="form-label">
                <i class="fas fa-lock" style="color:var(--accent);margin-right:.35rem"></i>New Password
            </label>
            <div class="password-toggle">
                <input type="password" name="newPassword" id="newPwd" class="form-control"
                       placeholder="Enter new password" required autocomplete="new-password" />
                <button type="button" class="toggle-btn" onclick="togglePwd('newPwd', this)">
                    <i class="fas fa-eye"></i>
                </button>
            </div>

            <!-- Strength Bars -->
            <div style="display:flex;gap:.3rem;margin-top:.5rem" id="strengthBars">
                <div class="sbar" id="sb1"></div>
                <div class="sbar" id="sb2"></div>
                <div class="sbar" id="sb3"></div>
                <div class="sbar" id="sb4"></div>
            </div>
            <div id="strengthLabel" style="font-size:.75rem;color:var(--muted);margin-top:.25rem;min-height:1rem"></div>
        </div>

        <!-- CONFIRM PASSWORD -->
        <div class="mb-4">
            <label class="form-label">
                <i class="fas fa-lock-open" style="color:var(--accent);margin-right:.35rem"></i>Confirm New Password
            </label>
            <div class="password-toggle">
                <input type="password" name="confirmPassword" id="conPwd" class="form-control"
                       placeholder="Confirm new password" required autocomplete="new-password" />
                <button type="button" class="toggle-btn" onclick="togglePwd('conPwd', this)">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
            <div id="matchMsg" style="font-size:.75rem;margin-top:.25rem;min-height:1rem"></div>
        </div>

        <button type="submit" class="btn-primary-ice mb-3" id="submitBtn">
            <i class="fas fa-rotate" style="margin-right:.5rem"></i>Reset Password
        </button>
    </form>

    <div class="divider">OR</div>

    <div style="text-align:center">
        <a asp-action="ForgotPassword" style="font-size:.875rem">
            <i class="fas fa-envelope" style="margin-right:.35rem"></i>Request a new PIN
        </a>
        &nbsp;&nbsp;·&nbsp;&nbsp;
        <a asp-action="Login" style="font-size:.875rem">
            <i class="fas fa-arrow-left" style="margin-right:.35rem"></i>Back to Login
        </a>
    </div>
</div>

<style>
    .sbar { height: 4px; flex: 1; border-radius: 4px; background: var(--border); transition: background .3s; }
</style>

@section Scripts {
    <script>
        // Toggle password visibility
        function togglePwd(id, btn) {
            const f = document.getElementById(id);
            const i = btn.querySelector('i');
            f.type = f.type === 'password' ? 'text' : 'password';
            i.classList.toggle('fa-eye');
            i.classList.toggle('fa-eye-slash');
        }

        // PIN: digits only
        document.getElementById('pinInput').addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 6);
        });

        // Password strength
        document.getElementById('newPwd').addEventListener('input', function () {
            const v = this.value;
            let s = 0;
            if (v.length >= 8) s++;
            if (/[A-Z]/.test(v)) s++;
            if (/[0-9]/.test(v)) s++;
            if (/[^A-Za-z0-9]/.test(v)) s++;
            const colors = ['', '#ef4444', '#f59e0b', '#38bdf8', '#22c55e'];
            const labels = ['', 'Weak — add more variety', 'Fair — getting better', 'Good — almost there', 'Strong — great password!'];
            for (let i = 1; i <= 4; i++) {
                document.getElementById('sb' + i).style.background = i <= s ? colors[s] : 'var(--border)';
            }
            const lbl = document.getElementById('strengthLabel');
            lbl.textContent = v.length ? labels[s] : '';
            lbl.style.color = colors[s];
            checkMatch();
        });

        // Match check
        document.getElementById('conPwd').addEventListener('input', checkMatch);
        function checkMatch() {
            const m = document.getElementById('matchMsg');
            const p1 = document.getElementById('newPwd').value;
            const p2 = document.getElementById('conPwd').value;
            if (!p2) { m.textContent = ''; return; }
            if (p1 === p2) {
                m.textContent = '✓ Passwords match';
                m.style.color = 'var(--success)';
            } else {
                m.textContent = '✗ Passwords do not match';
                m.style.color = 'var(--danger)';
            }
        }

        // 5-minute countdown
        let seconds = 300;
        const countdownEl = document.getElementById('countdown');
        const timer = setInterval(() => {
            seconds--;
            if (seconds <= 0) {
                clearInterval(timer);
                countdownEl.textContent = 'EXPIRED';
                countdownEl.style.color = 'var(--danger)';
                document.getElementById('submitBtn').disabled = true;
                document.getElementById('submitBtn').style.opacity = '.5';
                return;
            }
            const m = Math.floor(seconds / 60);
            const s = seconds % 60;
            countdownEl.textContent = `${m}:${s.toString().padStart(2, '0')}`;
            if (seconds <= 60) countdownEl.style.color = 'var(--danger)';
        }, 1000);
    </script>
}
