@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
    ViewData["Title"] = "Reset Password";
}

<div class="auth-card">
    <a asp-action="ForgotPassword" asp-controller="Account"
       class="d-inline-flex align-items-center gap-2 mb-3"
       style="font-size:.82rem;color:var(--muted);text-decoration:none">
        <i class="fas fa-arrow-left"></i> Back
    </a>

    <div class="auth-title">Reset Password</div>
    <div class="auth-subtitle">Enter the 6-digit PIN from your email and choose a new password</div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-ice-success mb-3">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-ice-danger mb-3">
            <i class="fas fa-circle-xmark"></i> @TempData["ErrorMessage"]
        </div>
    }

    <form asp-action="ResetPassword" asp-controller="Account" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label for="pin" class="form-label"><i class="fas fa-key me-1"></i> 6-Digit PIN</label>
            <input type="text" id="pin" name="pin" class="form-control"
                   placeholder="· · · · · ·" maxlength="6" pattern="\d{6}"
                   inputmode="numeric" autocomplete="one-time-code" required autofocus
                   style="letter-spacing:6px;font-size:1.4rem;text-align:center;font-family:'Rajdhani',sans-serif;font-weight:700" />
            <div style="font-size:.75rem;color:var(--muted);margin-top:.35rem">
                <i class="fas fa-clock me-1" style="color:var(--warning)"></i> PIN expires in 5 minutes
            </div>
        </div>

        <div class="mb-3">
            <label for="newPassword" class="form-label"><i class="fas fa-lock me-1"></i> New Password</label>
            <div class="password-toggle">
                <input type="password" id="newPassword" name="newPassword" class="form-control"
                       placeholder="Enter new password" required autocomplete="new-password"
                       oninput="checkStrength(this.value)" />
                <button type="button" class="toggle-btn" onclick="togglePwd('newPassword',this)" tabindex="-1">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
            <div style="margin-top:.5rem">
                <div style="height:4px;border-radius:2px;background:var(--input-bg);overflow:hidden">
                    <div id="strengthBar" style="height:100%;width:0;border-radius:2px;transition:all .3s"></div>
                </div>
                <div id="strengthLabel" style="font-size:.72rem;color:var(--muted);margin-top:.2rem"></div>
            </div>
        </div>

        <div class="mb-4">
            <label for="confirmPwd" class="form-label"><i class="fas fa-lock-open me-1"></i> Confirm New Password</label>
            <div class="password-toggle">
                <input type="password" id="confirmPwd" class="form-control"
                       placeholder="Re-enter new password" autocomplete="new-password"
                       oninput="checkMatch()" />
                <button type="button" class="toggle-btn" onclick="togglePwd('confirmPwd',this)" tabindex="-1">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
            <div id="matchMsg" style="font-size:.75rem;margin-top:.3rem"></div>
        </div>

        <button type="submit" class="btn-primary-ice">
            <i class="fas fa-rotate-right me-2"></i>Reset Password
        </button>
    </form>
</div>

@section Scripts {
    <script>
        function togglePwd(id, btn) {
            const inp = document.getElementById(id), icon = btn.querySelector('i');
            if (inp.type === 'password') { inp.type = 'text'; icon.classList.replace('fa-eye','fa-eye-slash'); }
            else { inp.type = 'password'; icon.classList.replace('fa-eye-slash','fa-eye'); }
        }
        function checkStrength(val) {
            const bar = document.getElementById('strengthBar'), lbl = document.getElementById('strengthLabel');
            const score = [val.length >= 8, /[A-Z]/.test(val), /[0-9]/.test(val), /[^A-Za-z0-9]/.test(val)].filter(Boolean).length;
            const lvls = [['0%','',''],['25%','#ef4444','Weak'],['50%','#f59e0b','Fair'],['75%','#38bdf8','Good'],['100%','#22c55e','Strong']];
            bar.style.width = lvls[score][0]; bar.style.background = lvls[score][1];
            lbl.style.color = lvls[score][1]; lbl.textContent = lvls[score][2] ? 'Strength: ' + lvls[score][2] : '';
        }
        function checkMatch() {
            const p1 = document.getElementById('newPassword').value;
            const p2 = document.getElementById('confirmPwd').value;
            const msg = document.getElementById('matchMsg');
            if (!p2) { msg.textContent = ''; return; }
            if (p1 === p2) { msg.style.color = '#22c55e'; msg.innerHTML = '<i class="fas fa-check-circle"></i> Passwords match'; }
            else           { msg.style.color = '#ef4444'; msg.innerHTML = '<i class="fas fa-circle-xmark"></i> Passwords do not match'; }
        }
        document.getElementById('pin').addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 6);
        });
    </script>
}
