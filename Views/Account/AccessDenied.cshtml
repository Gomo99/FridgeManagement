@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Access Denied";
}
<div class="page-header">
    <h1>Access Denied</h1>
</div>
<div class="fms-card" style="max-width:400px; margin: 40px auto;">
    <div style="padding: 40px; text-align: center;">
        <div style="font-size: 3rem; color: var(--danger); margin-bottom: 20px;">
            <i class="fa-solid fa-lock"></i>
        </div>
        <h2 style="color: var(--white);">403 Forbidden</h2>
        <p style="color: var(--muted);">You do not have permission to view this page.</p>
        <a asp-controller="Home" asp-action="Index" class="btn-fms btn-primary-fms mt-3">
            <i class="fa-solid fa-house"></i> Go Home
        </a>
    </div>
</div>