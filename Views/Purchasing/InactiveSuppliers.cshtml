@model IEnumerable<FridgeManagement.Models.Supplier>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inactive Suppliers";
    ViewData["ActivePage"] = "Suppliers";
}

<div class="page-header">
    <div>
        <h1>Inactive Suppliers</h1>
        <p>Soft‑deleted suppliers</p>
    </div>
    <a asp-action="Suppliers" class="btn-fms btn-ghost-fms"><i class="fa-solid fa-arrow-left"></i> Back to Active</a>
</div>

<div class="fms-card">
    <div class="fms-card-header">
        <div class="fms-card-title">Deactivated Suppliers</div>
        <div class="search-bar">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="inactSearch" placeholder="Search..." oninput="filterTable()" />
        </div>
    </div>
    <table class="fms-table" id="inactTable">
        <thead>
            <tr>
                <th>Company Name</th>
                <th>Contact Person</th>
                <th>Phone</th>
                <th>Email</th>
                <th style="text-align:right;">Restore</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var supp in Model)
            {
                <tr data-search="@supp.Name @supp.ContactPerson @supp.Email">
                    <td>@supp.Name</td>
                    <td>@supp.ContactPerson</td>
                    <td>@supp.PhoneNumber</td>
                    <td>@supp.Email</td>
                    <td style="text-align:right;">
                        <button class="btn-fms btn-success-fms btn-sm-fms"
                                onclick="openRestoreModal(@supp.Id, '@supp.Name.Replace("'", "\\'")')">
                            <i class="fa-solid fa-rotate-left"></i> Restore
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ═══════ RESTORE SUPPLIER MODAL ═══════ -->
<div class="fms-modal-overlay" id="restoreSupplierModal">
    <div class="fms-modal" style="max-width:400px;">
        <div class="fms-modal-header">
            <div class="fms-modal-title"><i class="fa-solid fa-rotate-left" style="color:var(--success); margin-right:10px;"></i>Restore Supplier</div>
            <button class="fms-modal-close" onclick="closeModal('restoreSupplierModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div style="padding:20px; text-align:center;">
            <p>Reactivate <strong id="restSuppName"></strong>?</p>
            <div style="display:flex; gap:10px; justify-content:center; margin-top:20px;">
                <button type="button" class="btn-fms btn-ghost-fms" onclick="closeModal('restoreSupplierModal')">Cancel</button>
                <form asp-action="RestoreSupplier" method="post" id="restoreSupplierForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="restSuppId" />
                    <button type="submit" class="btn-fms btn-success-fms">Restore</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(id) { document.getElementById(id).classList.add('show'); }
        function closeModal(id) { document.getElementById(id).classList.remove('show'); }
        document.querySelectorAll('.fms-modal-overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('show'); }));

        function filterTable() {
            const q = document.getElementById('inactSearch').value.toLowerCase();
            document.querySelectorAll('#inactTable tbody tr').forEach(row => {
                row.style.display = (row.dataset.search || '').toLowerCase().includes(q) ? '' : 'none';
            });
        }

        function openRestoreModal(id, name) {
            document.getElementById('restSuppId').value   = id;
            document.getElementById('restSuppName').textContent = name;
            openModal('restoreSupplierModal');
        }
    </script>
}