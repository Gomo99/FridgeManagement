<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FridgeMS</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg:        #050d1a;
            --sidebar-bg:#071528;
            --card:      #0c1929;
            --card2:     #0f1f35;
            --input-bg:  #0f1f35;
            --border:    rgba(56,189,248,.15);
            --accent:    #38bdf8;
            --accent2:   #0ea5e9;
            --glow:      rgba(56,189,248,.12);
            --success:   #22c55e;
            --danger:    #ef4444;
            --warning:   #f59e0b;
            --info:      #818cf8;
            --text:      #e2e8f0;
            --muted:     #64748b;
            --sidebar-w: 260px;
            --header-h:  60px;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Nunito', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; overflow-x: hidden; }

        /* ===== SIDEBAR ===== */
        .sidebar {
            position: fixed; top: 0; left: 0; bottom: 0;
            width: var(--sidebar-w);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex; flex-direction: column;
            z-index: 100; overflow-y: auto;
            transition: transform .3s;
        }
        .sidebar-header {
            padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: .75rem; flex-shrink: 0;
        }
        .sidebar-logo-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, rgba(56,189,248,.25), rgba(14,165,233,.35));
            border: 1px solid rgba(56,189,248,.4); border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; color: var(--accent); flex-shrink: 0;
        }
        .sidebar-brand { font-family: 'Rajdhani', sans-serif; font-size: 1.2rem; font-weight: 700; color: #fff; letter-spacing: 1px; }
        .sidebar-brand span { color: var(--accent); }

        .sidebar-section-label {
            padding: 1rem 1.5rem .4rem;
            font-size: .65rem; font-weight: 700; letter-spacing: 1.5px;
            text-transform: uppercase; color: var(--muted);
        }
        .nav-item-link {
            display: flex; align-items: center; gap: .75rem;
            padding: .6rem 1.5rem; font-size: .875rem; color: #94a3b8;
            text-decoration: none; transition: all .15s; position: relative;
            border-left: 2px solid transparent;
        }
        .nav-item-link i { width: 18px; text-align: center; font-size: .85rem; }
        .nav-item-link:hover { color: var(--text); background: rgba(56,189,248,.06); }
        .nav-item-link.active {
            color: var(--accent); background: rgba(56,189,248,.1);
            border-left-color: var(--accent); font-weight: 600;
        }
        .sidebar-footer {
            margin-top: auto; padding: 1rem 1.5rem;
            border-top: 1px solid var(--border);
        }
        .user-chip {
            display: flex; align-items: center; gap: .65rem;
            padding: .6rem .8rem; border-radius: 10px;
            background: var(--card2); border: 1px solid var(--border);
        }
        .user-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            display: flex; align-items: center; justify-content: center;
            font-size: .8rem; font-weight: 700; color: #000; flex-shrink: 0;
        }
        .user-chip-info { flex: 1; overflow: hidden; }
        .user-chip-name { font-size: .8rem; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .user-chip-role { font-size: .7rem; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* ===== MAIN CONTENT ===== */
        .main-wrapper { margin-left: var(--sidebar-w); min-height: 100vh; display: flex; flex-direction: column; }
        .topbar {
            position: sticky; top: 0; z-index: 50;
            height: var(--header-h);
            background: rgba(5,13,26,.92); backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
            padding: 0 2rem; gap: 1rem;
        }
        .topbar-title { font-family: 'Rajdhani', sans-serif; font-size: 1.1rem; font-weight: 600; color: var(--text); flex: 1; }
        .topbar-actions { display: flex; align-items: center; gap: .75rem; }
        .topbar-btn {
            width: 36px; height: 36px; border-radius: 8px;
            background: var(--card2); border: 1px solid var(--border);
            color: var(--muted); display: flex; align-items: center; justify-content: center;
            text-decoration: none; transition: all .15s; cursor: pointer;
        }
        .topbar-btn:hover { color: var(--accent); border-color: var(--accent); }
        .topbar-user {
            display: flex; align-items: center; gap: .5rem;
            padding: .35rem .75rem; border-radius: 8px;
            background: var(--card2); border: 1px solid var(--border);
            font-size: .8rem; color: var(--text);
        }
        .topbar-user .avatar {
            width: 26px; height: 26px; border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            display: flex; align-items: center; justify-content: center;
            font-size: .7rem; font-weight: 700; color: #000;
        }
        .page-content { flex: 1; padding: 2rem; }

        /* ===== CARDS ===== */
        .ice-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 12px; padding: 1.5rem;
            transition: border-color .2s;
        }
        .ice-card:hover { border-color: rgba(56,189,248,.3); }
        .ice-card-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 1.25rem; padding-bottom: 1rem;
            border-bottom: 1px solid var(--border);
        }
        .ice-card-title {
            font-family: 'Rajdhani', sans-serif; font-size: 1.1rem;
            font-weight: 700; color: #fff; display: flex; align-items: center; gap: .5rem;
        }
        .ice-card-title i { color: var(--accent); }
        .stat-card {
            background: var(--card); border: 1px solid var(--border);
            border-radius: 12px; padding: 1.25rem;
            display: flex; align-items: center; gap: 1rem;
            transition: all .2s;
        }
        .stat-card:hover { border-color: rgba(56,189,248,.3); transform: translateY(-1px); }
        .stat-icon {
            width: 48px; height: 48px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.25rem; flex-shrink: 0;
        }
        .stat-icon.blue { background: rgba(56,189,248,.15); color: var(--accent); }
        .stat-icon.green { background: rgba(34,197,94,.15); color: var(--success); }
        .stat-icon.red { background: rgba(239,68,68,.15); color: var(--danger); }
        .stat-icon.yellow { background: rgba(245,158,11,.15); color: var(--warning); }
        .stat-icon.purple { background: rgba(129,140,248,.15); color: var(--info); }
        .stat-value { font-family: 'Rajdhani', sans-serif; font-size: 1.6rem; font-weight: 700; color: #fff; }
        .stat-label { font-size: .75rem; color: var(--muted); margin-top: .1rem; }

        /* ===== TABLES ===== */
        .ice-table { width: 100%; border-collapse: separate; border-spacing: 0 .35rem; }
        .ice-table thead th {
            padding: .6rem 1rem; font-size: .7rem; font-weight: 700;
            letter-spacing: 1px; text-transform: uppercase; color: var(--muted);
            border-bottom: 1px solid var(--border); background: transparent;
        }
        .ice-table tbody tr {
            background: var(--card2); border-radius: 8px;
            transition: background .15s;
        }
        .ice-table tbody tr:hover { background: rgba(56,189,248,.07); }
        .ice-table tbody td {
            padding: .75rem 1rem; font-size: .875rem; color: var(--text);
            border-bottom: 1px solid rgba(255,255,255,.03);
        }
        .ice-table tbody td:first-child { border-radius: 8px 0 0 8px; }
        .ice-table tbody td:last-child { border-radius: 0 8px 8px 0; }

        /* ===== BADGES ===== */
        .badge-ice { padding: .3rem .65rem; border-radius: 6px; font-size: .72rem; font-weight: 700; letter-spacing: .3px; }
        .badge-ice.active   { background: rgba(34,197,94,.15);  color: #86efac; }
        .badge-ice.inactive { background: rgba(239,68,68,.15);  color: #fca5a5; }
        .badge-ice.pending  { background: rgba(245,158,11,.15); color: #fcd34d; }
        .badge-ice.info     { background: rgba(56,189,248,.15); color: var(--accent); }
        .badge-ice.purple   { background: rgba(129,140,248,.15);color: #a5b4fc; }

        /* ===== FORMS ===== */
        .form-label { font-size: .78rem; font-weight: 700; letter-spacing: .5px; text-transform: uppercase; color: #94a3b8; margin-bottom: .4rem; }
        .form-control, .form-select {
            background: var(--input-bg) !important; border: 1px solid var(--border) !important;
            color: var(--text) !important; border-radius: 8px !important;
            padding: .65rem .9rem !important; font-size: .875rem !important;
            font-family: 'Nunito', sans-serif !important; transition: border-color .2s, box-shadow .2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent) !important;
            box-shadow: 0 0 0 3px var(--glow) !important; outline: none !important;
        }
        .form-control::placeholder { color: var(--muted) !important; }
        .form-select option { background: var(--input-bg); color: var(--text); }

        /* ===== BUTTONS ===== */
        .btn-ice { background: linear-gradient(135deg, var(--accent), var(--accent2)); border: none; color: #000; font-weight: 700; border-radius: 8px; padding: .55rem 1.2rem; font-size: .85rem; font-family: 'Rajdhani', sans-serif; letter-spacing: .5px; text-transform: uppercase; transition: all .2s; }
        .btn-ice:hover { filter: brightness(1.1); box-shadow: 0 0 15px rgba(56,189,248,.3); color: #000; }
        .btn-ice-outline { background: transparent; border: 1px solid var(--accent); color: var(--accent); border-radius: 8px; padding: .5rem 1.1rem; font-size: .85rem; font-family: 'Nunito', sans-serif; font-weight: 600; transition: all .2s; }
        .btn-ice-outline:hover { background: var(--glow); color: var(--accent); }
        .btn-danger-ice { background: rgba(239,68,68,.15); border: 1px solid rgba(239,68,68,.3); color: #fca5a5; border-radius: 8px; padding: .5rem 1.1rem; font-size: .85rem; font-weight: 600; transition: all .2s; }
        .btn-danger-ice:hover { background: rgba(239,68,68,.25); color: #fca5a5; }
        .btn-success-ice { background: rgba(34,197,94,.15); border: 1px solid rgba(34,197,94,.3); color: #86efac; border-radius: 8px; padding: .5rem 1.1rem; font-size: .85rem; font-weight: 600; transition: all .2s; }
        .btn-success-ice:hover { background: rgba(34,197,94,.25); color: #86efac; }

        /* ===== ALERTS ===== */
        .alert-ice-success { background: rgba(34,197,94,.1); border: 1px solid rgba(34,197,94,.3); color: #86efac; border-radius: 8px; padding: .8rem 1rem; font-size: .875rem; display: flex; align-items: center; gap: .5rem; }
        .alert-ice-danger   { background: rgba(239,68,68,.1);  border: 1px solid rgba(239,68,68,.3);  color: #fca5a5; border-radius: 8px; padding: .8rem 1rem; font-size: .875rem; display: flex; align-items: center; gap: .5rem; }
        .alert-ice-warning  { background: rgba(245,158,11,.1); border: 1px solid rgba(245,158,11,.3); color: #fcd34d; border-radius: 8px; padding: .8rem 1rem; font-size: .875rem; display: flex; align-items: center; gap: .5rem; }
        .text-danger { color: #fca5a5 !important; font-size: .8rem; }

        /* ===== MISC ===== */
        a { color: var(--accent); text-decoration: none; }
        a:hover { color: var(--accent2); }
        .page-header { margin-bottom: 1.75rem; }
        .page-header h1 { font-family: 'Rajdhani', sans-serif; font-size: 1.5rem; font-weight: 700; color: #fff; }
        .page-header p { font-size: .875rem; color: var(--muted); margin-top: .2rem; }
        .breadcrumb { background: none; padding: 0; font-size: .8rem; margin-bottom: .5rem; }
        .breadcrumb-item { color: var(--muted); }
        .breadcrumb-item a { color: var(--muted); }
        .breadcrumb-item a:hover { color: var(--accent); }
        .breadcrumb-item.active { color: var(--text); }
        .breadcrumb-item + .breadcrumb-item::before { color: var(--muted); }
        .password-toggle { position: relative; }
        .password-toggle .toggle-btn { position: absolute; right: .75rem; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--muted); cursor: pointer; padding: 0; z-index: 5; transition: color .2s; }
        .password-toggle .toggle-btn:hover { color: var(--accent); }

        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .main-wrapper { margin-left: 0; }
        }
    </style>
</head>
<body>
    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo-icon"><i class="fa-solid fa-temperature-low"></i></div>
            <div class="sidebar-brand">Fridge<span>MS</span></div>
        </div>

        @{
            var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
            var fullName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "User";
            var initials = fullName.Length > 0 ? string.Concat(fullName.Split(' ').Take(2).Select(n => n[0].ToString().ToUpper())) : "U";
        }

        <!-- ADMIN NAVIGATION -->
        @if (role == "ADMINISTRATOR")
        {
            <div class="sidebar-section-label">Administration</div>
            <a asp-controller="Admin" asp-action="DashBoard" class="nav-item-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "DashBoard" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                <i class="fas fa-gauge-high"></i> Dashboard
            </a>
            <a asp-controller="Admin" asp-action="ManageCustomers" class="nav-item-link"><i class="fas fa-users"></i> Customers</a>
            <a asp-controller="Admin" asp-action="ManageEmployees" class="nav-item-link"><i class="fas fa-user-tie"></i> Employees</a>
            <a asp-controller="Admin" asp-action="ManageLocations" class="nav-item-link"><i class="fas fa-location-dot"></i> Locations</a>
            <a asp-controller="Admin" asp-action="ManageFridges" class="nav-item-link"><i class="fas fa-snowflake"></i> Fridges</a>
            <a asp-controller="Admin" asp-action="ManageSuppliers" class="nav-item-link"><i class="fas fa-truck"></i> Suppliers</a>
            <a asp-controller="Admin" asp-action="ServiceCheckTypes" class="nav-item-link"><i class="fas fa-list-check"></i> Service Checks</a>
            <a asp-controller="Admin" asp-action="BusinessInfo" class="nav-item-link"><i class="fas fa-building"></i> Business Info</a>
        }

        <!-- CUSTOMER LIAISON NAVIGATION -->
        @if (role == "CUSTOMERLIAISON")
        {
            <div class="sidebar-section-label">Customer Service</div>
            <a asp-controller="CustomerLiaisonManagement" asp-action="DashBoard" class="nav-item-link"><i class="fas fa-gauge-high"></i> Dashboard</a>
            <a asp-controller="CustomerLiaisonManagement" asp-action="ManageCustomers" class="nav-item-link"><i class="fas fa-users"></i> Manage Customers</a>
            <a asp-controller="CustomerLiaisonManagement" asp-action="FridgeAllocations" class="nav-item-link"><i class="fas fa-snowflake"></i> Fridge Allocations</a>
            <a asp-controller="CustomerLiaisonManagement" asp-action="CreateAllocation" class="nav-item-link"><i class="fas fa-plus-circle"></i> Create Allocation</a>
        }

        <!-- INVENTORY LIAISON NAVIGATION -->
        @if (role == "INVENTORYLIAISON")
        {
            <div class="sidebar-section-label">Inventory Control</div>
            <a asp-controller="InventoryLiaisonManagement" asp-action="DashBoard" class="nav-item-link"><i class="fas fa-gauge-high"></i> Dashboard</a>
            <a asp-controller="InventoryLiaisonManagement" asp-action="FridgeInventory" class="nav-item-link"><i class="fas fa-warehouse"></i> Fridge Inventory</a>
            <a asp-controller="InventoryLiaisonManagement" asp-action="ReceiveFridges" class="nav-item-link"><i class="fas fa-truck-ramp-box"></i> Receive Fridges</a>
            <a asp-controller="InventoryLiaisonManagement" asp-action="ScrapFridges" class="nav-item-link"><i class="fas fa-trash-can"></i> Scrap Fridges</a>
            <a asp-controller="InventoryLiaisonManagement" asp-action="ProcessAllocations" class="nav-item-link"><i class="fas fa-right-left"></i> Process Allocations</a>
            <a asp-controller="InventoryLiaisonManagement" asp-action="CreatePurchaseRequest" class="nav-item-link"><i class="fas fa-file-circle-plus"></i> Purchase Requests</a>
        }

        <!-- CUSTOMER NAVIGATION -->
        @if (role == "CUSTOMER")
        {
            <div class="sidebar-section-label">My Account</div>
            <a asp-controller="Customer" asp-action="DashBoard" class="nav-item-link"><i class="fas fa-gauge-high"></i> Dashboard</a>
            <a asp-controller="Customer" asp-action="MyFridges" class="nav-item-link"><i class="fas fa-snowflake"></i> My Fridges</a>
            <a asp-controller="Customer" asp-action="ReportFault" class="nav-item-link"><i class="fas fa-triangle-exclamation"></i> Report Fault</a>
            <a asp-controller="Customer" asp-action="MyFaults" class="nav-item-link"><i class="fas fa-clipboard-list"></i> My Fault Reports</a>
            <a asp-controller="Customer" asp-action="RequestFridge" class="nav-item-link"><i class="fas fa-plus-circle"></i> Request Fridge</a>
            <a asp-controller="Customer" asp-action="MyRequests" class="nav-item-link"><i class="fas fa-file-alt"></i> My Requests</a>
            <a asp-controller="Customer" asp-action="MaintenanceVisits" class="nav-item-link"><i class="fas fa-calendar-check"></i> Maintenance Visits</a>
        }

        <!-- FAULT TECHNICIAN NAVIGATION -->
        @if (role == "FAULTTECHNICIAN")
        {
            <div class="sidebar-section-label">Fault Management</div>
            <a asp-controller="FaultTechnician" asp-action="DashBoard" class="nav-item-link"><i class="fas fa-gauge-high"></i> Dashboard</a>
            <a asp-controller="FaultTechnician" asp-action="ViewFaults" class="nav-item-link"><i class="fas fa-triangle-exclamation"></i> All Faults</a>
            <a asp-controller="FaultTechnician" asp-action="ProcessFault" class="nav-item-link"><i class="fas fa-wrench"></i> Process Fault</a>
            <a asp-controller="FaultTechnician" asp-action="RepairHistory" class="nav-item-link"><i class="fas fa-history"></i> Repair History</a>
        }

        <!-- MAINTENANCE TECHNICIAN NAVIGATION -->
        @if (role == "MAINTENANCETECHNICIAN")
        {
            <div class="sidebar-section-label">Maintenance</div>
            <a asp-controller="Maintenance" asp-action="DashBoard" class="nav-item-link"><i class="fas fa-gauge-high"></i> Dashboard</a>
            <a asp-controller="Maintenance" asp-action="CustomerFridges" class="nav-item-link"><i class="fas fa-snowflake"></i> Customer Fridges</a>
            <a asp-controller="Maintenance" asp-action="ScheduleVisit" class="nav-item-link"><i class="fas fa-calendar-plus"></i> Schedule Visit</a>
            <a asp-controller="Maintenance" asp-action="ManageVisits" class="nav-item-link"><i class="fas fa-calendar-check"></i> Manage Visits</a>
            <a asp-controller="Maintenance" asp-action="ServiceFridge" class="nav-item-link"><i class="fas fa-screwdriver-wrench"></i> Service Fridge</a>
            <a asp-controller="Maintenance" asp-action="CreateFaultReport" class="nav-item-link"><i class="fas fa-file-circle-exclamation"></i> Create Fault</a>
        }

        <!-- PURCHASING MANAGER NAVIGATION -->
        @if (role == "PURCHASINGMANAGER")
        {
            <div class="sidebar-section-label">Procurement</div>
            <a asp-controller="Purchasing" asp-action="DashBoard" class="nav-item-link"><i class="fas fa-gauge-high"></i> Dashboard</a>
            <a asp-controller="Purchasing" asp-action="ManageSuppliers" class="nav-item-link"><i class="fas fa-truck"></i> Suppliers</a>
            <a asp-controller="Purchasing" asp-action="PurchaseRequests" class="nav-item-link"><i class="fas fa-file-alt"></i> Purchase Requests</a>
            <a asp-controller="Purchasing" asp-action="Rfqs" class="nav-item-link"><i class="fas fa-file-invoice"></i> RFQs</a>
            <a asp-controller="Purchasing" asp-action="Quotations" class="nav-item-link"><i class="fas fa-file-invoice-dollar"></i> Quotations</a>
            <a asp-controller="Purchasing" asp-action="PurchaseOrders" class="nav-item-link"><i class="fas fa-shopping-cart"></i> Purchase Orders</a>
            <a asp-controller="Purchasing" asp-action="DeliveryNotes" class="nav-item-link"><i class="fas fa-clipboard-check"></i> Delivery Notes</a>
        }

        <!-- SUPPLIER NAVIGATION -->
        @if (role == "SUPPLIER")
        {
            <div class="sidebar-section-label">Supplier Portal</div>
            <a asp-controller="Supplier" asp-action="DashBoard" class="nav-item-link"><i class="fas fa-gauge-high"></i> Dashboard</a>
            <a asp-controller="Supplier" asp-action="ViewRfqs" class="nav-item-link"><i class="fas fa-file-invoice"></i> View RFQs</a>
            <a asp-controller="Supplier" asp-action="SubmitQuotation" class="nav-item-link"><i class="fas fa-file-invoice-dollar"></i> Submit Quotation</a>
            <a asp-controller="Supplier" asp-action="DeliveryNotes" class="nav-item-link"><i class="fas fa-truck-ramp-box"></i> Delivery Notes</a>
        }

        <!-- SHARED ACCOUNT SECTION -->
        <div class="sidebar-section-label" style="margin-top:auto">Account</div>
        <a asp-controller="Account" asp-action="ViewProfile" class="nav-item-link"><i class="fas fa-user-circle"></i> My Profile</a>
        <a asp-controller="Account" asp-action="ChangePassword" class="nav-item-link"><i class="fas fa-lock"></i> Change Password</a>
        <a asp-controller="Account" asp-action="ManageDevices" class="nav-item-link"><i class="fas fa-mobile-screen"></i> Trusted Devices</a>
        <form asp-controller="Account" asp-action="Logout" method="post" style="margin:.25rem 0">
            @Html.AntiForgeryToken()
            <button type="submit" class="nav-item-link w-100 text-start border-0" style="background:none;cursor:pointer;color:#ef4444;"><i class="fas fa-right-from-bracket" style="color:#ef4444"></i> Sign Out</button>
        </form>

        <div class="sidebar-footer">
            <div class="user-chip">
                <div class="user-avatar">@initials</div>
                <div class="user-chip-info">
                    <div class="user-chip-name">@fullName</div>
                    <div class="user-chip-role">@role?.Replace("_", " ")</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- MAIN WRAPPER -->
    <div class="main-wrapper">
        <!-- TOPBAR -->
        <header class="topbar">
            <button class="topbar-btn d-md-none border-0" onclick="document.getElementById('sidebar').classList.toggle('open')">
                <i class="fas fa-bars"></i>
            </button>
            <div class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</div>
            <div class="topbar-actions">
                @if (TempData["SuccessMessage"] != null)
                {
                    <span style="font-size:.8rem;color:var(--success)"><i class="fas fa-check-circle"></i></span>
                }
                <a asp-controller="Account" asp-action="ViewProfile" class="topbar-btn" title="My Profile">
                    <i class="fas fa-user-circle"></i>
                </a>
                <div class="topbar-user">
                    <div class="avatar">@initials</div>
                    <span>@fullName</span>
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="page-content">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-ice-success mb-3" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-ice-danger mb-3" role="alert">
                    <i class="fas fa-circle-xmark"></i> @TempData["ErrorMessage"]
                </div>
            }
            @if (TempData["WarningMessage"] != null)
            {
                <div class="alert-ice-warning mb-3" role="alert">
                    <i class="fas fa-triangle-exclamation"></i> @TempData["WarningMessage"]
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
