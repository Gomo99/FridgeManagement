@model FridgeManagement.Models.FaultReport
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = $"Fault #{Model.Id} Details";
    // Timeline events (dates and descriptions)
    var timelineEvents = new List<dynamic>();
    if (Model.ReportedDate != null)
        timelineEvents.Add(new { Date = Model.ReportedDate, Type = "Reported", Desc = "Fault reported by customer.", Icon = "fa-paper-plane", Color = "#F0637A" });
    if (Model.AssignedDate != null)
        timelineEvents.Add(new { Date = Model.AssignedDate.Value, Type = "Assigned", Desc = $"Assigned to {Model.AssignedTechnician?.FullName ?? "technician"}.", Icon = "fa-user-check", Color = "#5FD4E0" });
    if (Model.ScheduledRepairDate != null)
        timelineEvents.Add(new { Date = Model.ScheduledRepairDate.Value, Type = "Scheduled", Desc = "Repair appointment scheduled.", Icon = "fa-calendar-alt", Color = "#F5A623" });
    if (!string.IsNullOrEmpty(Model.DiagnosisNotes))
        timelineEvents.Add(new { Date = Model.ReportedDate.AddDays(1), Type = "Diagnosed", Desc = Model.DiagnosisNotes, Icon = "fa-stethoscope", Color = "#5D9CEC" });
    if (Model.RepairStartedAt != null)
        timelineEvents.Add(new { Date = Model.RepairStartedAt.Value, Type = "Repair Started", Desc = "Technician began repair work.", Icon = "fa-wrench", Color = "#A78BFA" });
    if (Model.RepairCompletedAt != null || Model.Status == FaultStatus.Repaired)
        timelineEvents.Add(new { Date = Model.RepairCompletedAt ?? Model.ResolvedDate ?? DateTime.Now, Type = "Repair Completed", Desc = Model.ResolutionNotes ?? "Fault repaired.", Icon = "fa-circle-check", Color = "#3ECF8E" });
    if (Model.Status == FaultStatus.Closed || Model.IsDeleted)
        timelineEvents.Add(new { Date = DateTime.Now, Type = "Closed", Desc = "Fault closed.", Icon = "fa-lock", Color = "#8FAEBE" });
    timelineEvents = timelineEvents.OrderBy(e => e.Date).ToList();
}

<div class="page-header">
    <div>
        <h1>Fault #@Model.Id</h1>
        <p>@Model.Fridge?.SerialNumber – @Model.Description</p>
    </div>
    <a asp-action="Index" class="btn-fms btn-ghost-fms">
        <i class="fa-solid fa-arrow-left"></i> Back to Faults
    </a>
</div>

<!-- Tabs Navigation -->
<div class="fridge-tabs">
    <button class="fridge-tab active" data-tab="overview">Overview</button>
    <button class="fridge-tab" data-tab="customer">Customer</button>
    <button class="fridge-tab" data-tab="fridge">Fridge</button>
    <button class="fridge-tab" data-tab="notes">Notes</button>
    <button class="fridge-tab" data-tab="timeline">Timeline</button>
</div>

<!-- Tab Panels -->
<div id="tab-overview" class="fridge-tab-panel active">
    <div class="fms-card" style="margin-bottom:20px;">
        <div class="fms-card-header"><div class="fms-card-title">General Information</div></div>
        <div style="padding:20px; display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
            <div><strong>Fault ID:</strong> #@Model.Id</div>
            <div><strong>Reported Date:</strong> @Model.ReportedDate.ToString("yyyy-MM-dd HH:mm")</div>
            <div><strong>Priority:</strong> <span class="fms-badge @(Model.Priority >= FaultPriority.High ? "red" : "orange")">@Model.Priority</span></div>
            <div><strong>Current Status:</strong> <span class="fms-badge @(Model.Status == FaultStatus.Closed ? "gray" : Model.Status == FaultStatus.Repaired ? "green" : "blue")">@Model.Status</span></div>
            <div><strong>Assigned Technician:</strong> @(Model.AssignedTechnician?.FullName ?? "Not assigned")</div>
            <div><strong>Scheduled Repair:</strong> @(Model.ScheduledRepairDate?.ToString("yyyy-MM-dd HH:mm") ?? "Not scheduled")</div>
            <div style="grid-column: span 2;"><strong>Description:</strong> @Model.Description</div>
            <div style="grid-column: span 2;"><strong>Diagnosis Notes:</strong> @(Model.DiagnosisNotes ?? "None")</div>
            <div style="grid-column: span 2;"><strong>Resolution Notes:</strong> @(Model.ResolutionNotes ?? "None")</div>
            <div style="grid-column: span 2;"><strong>Resolved Date:</strong> @(Model.ResolvedDate?.ToString("yyyy-MM-dd HH:mm") ?? "Not resolved")</div>
        </div>
    </div>
</div>

<div id="tab-customer" class="fridge-tab-panel" style="display:none;">
    <div class="fms-card">
        <div class="fms-card-header"><div class="fms-card-title">Customer Details</div></div>
        @if (Model.ReportedByCustomer != null)
        {
            <div style="padding:20px; display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
                <div><strong>Business Name:</strong> @Model.ReportedByCustomer.Name</div>
                <div><strong>Contact Person:</strong> @Model.ReportedByCustomer.ContactPerson</div>
                <div><strong>Phone:</strong> @Model.ReportedByCustomer.PhoneNumber</div>
                <div><strong>Email:</strong> @Model.ReportedByCustomer.Email</div>
                <div style="grid-column: span 2;"><strong>Address:</strong> @Model.ReportedByCustomer.Address</div>
            </div>
        }
        else
        {
            <div style="padding:20px;"><em>Customer information not available.</em></div>
        }
    </div>
</div>

<div id="tab-fridge" class="fridge-tab-panel" style="display:none;">
    <div class="fms-card">
        <div class="fms-card-header"><div class="fms-card-title">Fridge Details</div></div>
        @if (Model.Fridge != null)
        {
            <div style="padding:20px; display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
                <div><strong>Serial Number:</strong> @Model.Fridge.SerialNumber</div>
                <div><strong>Model:</strong> @Model.Fridge.Model</div>
                <div><strong>Brand:</strong> @Model.Fridge.Brand</div>
                <div><strong>Status:</strong> @Model.Fridge.Status</div>
                <div><strong>Purchase Date:</strong> @(Model.Fridge.PurchaseDate?.ToString("yyyy-MM-dd") ?? "N/A")</div>
                <div><strong>Warranty Expiry:</strong> @(Model.Fridge.WarrantyExpiryDate?.ToString("yyyy-MM-dd") ?? "N/A")</div>
            </div>
        }
        else
        {
            <div style="padding:20px;"><em>Fridge information not available.</em></div>
        }
    </div>
</div>

<div id="tab-notes" class="fridge-tab-panel" style="display:none;">
    <div class="fms-card" style="margin-bottom:20px;">
        <div class="fms-card-header"><div class="fms-card-title">Technician Notes</div></div>
        <div style="padding:20px;">
            @if (!string.IsNullOrEmpty(Model.TechnicianNotes))
            {
                <p>@Model.TechnicianNotes</p>
            }
            else
            {
                <em>No technician notes recorded.</em>
            }
        </div>
    </div>
    <div class="fms-card" style="margin-bottom:20px;">
        <div class="fms-card-header"><div class="fms-card-title">Customer Notes</div></div>
        <div style="padding:20px;">
            @if (!string.IsNullOrEmpty(Model.CustomerNotes))
            {
                <p>@Model.CustomerNotes</p>
            }
            else
            {
                <em>No customer notes recorded.</em>
            }
        </div>
    </div>
    <div class="fms-card">
        <div class="fms-card-header"><div class="fms-card-title">Manager Notes</div></div>
        <div style="padding:20px;">
            @if (!string.IsNullOrEmpty(Model.ManagerNotes))
            {
                <p>@Model.ManagerNotes</p>
            }
            else
            {
                <em>No manager notes recorded.</em>
            }
        </div>
    </div>
</div>

<div id="tab-timeline" class="fridge-tab-panel" style="display:none;">
    <div class="fms-card">
        <div class="fms-card-header"><div class="fms-card-title">Fault Timeline</div></div>
        <div class="timeline-container">
            @if (timelineEvents.Any())
            {
                foreach (var e in timelineEvents)
                {
                    <div class="timeline-item">
                        <div class="timeline-icon" style="background-color:@e.Color;">
                            <i class="fa-solid @e.Icon"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-date">@e.Date.ToString("yyyy-MM-dd HH:mm")</div>
                            <div class="timeline-type">@e.Type</div>
                            <div class="timeline-desc">@e.Desc</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="padding:20px;"><em>No timeline events recorded.</em></div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.fridge-tab').forEach(tab => {
            tab.addEventListener('click', function () {
                document.querySelectorAll('.fridge-tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.fridge-tab-panel').forEach(p => p.style.display = 'none');
                this.classList.add('active');
                document.getElementById('tab-' + this.dataset.tab).style.display = '';
            });
        });
    </script>
    <style>
        .fridge-tabs {
            display: flex;
            gap: 2px;
            margin-bottom: 20px;
            border-bottom: 2px solid var(--panel-border);
        }

        .fridge-tab {
            background: none;
            border: none;
            padding: 12px 20px;
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--text-muted);
            cursor: pointer;
            position: relative;
            transition: color 0.2s;
        }

            .fridge-tab.active {
                color: var(--ice);
            }

                .fridge-tab.active::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    right: 0;
                    height: 2px;
                    background: var(--ice);
                }

            .fridge-tab:hover:not(.active) {
                color: var(--text-primary);
            }

        .fridge-tab-panel {
            animation: fadeIn 0.25s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(5px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .timeline-container {
            padding: 20px 20px 20px 40px;
            position: relative;
        }

            .timeline-container::before {
                content: '';
                position: absolute;
                left: 28px;
                top: 0;
                bottom: 0;
                width: 3px;
                background: linear-gradient(to bottom, var(--ice), var(--panel-border));
                border-radius: 2px;
            }

        .timeline-item {
            display: flex;
            gap: 20px;
            margin-bottom: 25px;
            position: relative;
        }

        .timeline-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: white;
            font-size: 14px;
            box-shadow: 0 0 0 4px var(--panel-bg);
            z-index: 1;
        }

        .timeline-content {
            background: var(--panel-bg);
            border: 1px solid var(--panel-border);
            border-radius: 10px;
            padding: 12px 16px;
            flex: 1;
        }

        .timeline-date {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .timeline-type {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .timeline-desc {
            font-size: 0.85rem;
            color: var(--text-muted);
        }
    </style>
}