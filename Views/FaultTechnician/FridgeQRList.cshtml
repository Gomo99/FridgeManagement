@model IEnumerable<FridgeManagement.Models.Fridge>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Fridge QR Codes";
}

<div class="page-header">
    <div>
        <h1>Fridge QR Codes</h1>
        <p>Generate & print QR codes for all active fridges</p>
    </div>
    <a asp-action="DashBoard" class="btn-fms btn-ghost-fms">
        <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
    </a>
</div>

<div class="fms-card">
    <div class="fms-card-header">
        <div class="fms-card-title">Fridge List</div>
        <div class="search-bar">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="fridgeSearch" placeholder="Search fridges..." oninput="filterTable()" />
        </div>
    </div>
    <div style="overflow-x:auto;">
        <table class="fms-table" id="fridgeTable">
            <thead>
                <tr>
                    <th>Serial Number</th>
                    <th>Model</th>
                    <th>Brand</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model)
                {
                    <tr data-search="@f.SerialNumber @f.Model @f.Brand">
                        <td style="font-weight:600; color:var(--white);">@f.SerialNumber</td>
                        <td style="color:var(--muted);">@f.Model</td>
                        <td style="color:var(--muted);">@f.Brand</td>
                        <td style="text-align:right;">
                            <button class="btn-fms btn-ghost-fms btn-sm-fms" onclick="openQRModal(@f.Id, '@f.SerialNumber.Replace("'", "\\'")')">
                                <i class="fa-solid fa-qrcode"></i> QR
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- QR Code Modal -->
<div class="fms-modal-overlay" id="qrModal">
    <div class="fms-modal" style="max-width:360px; text-align:center;">
        <div class="fms-modal-header">
            <div class="fms-modal-title"><i class="fa-solid fa-qrcode" style="color:var(--ice); margin-right:10px;"></i>Fridge QR Code</div>
            <button class="fms-modal-close" onclick="closeModal('qrModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div style="padding:20px;">
            <img id="qrImage" src="" alt="QR Code" style="width:200px; height:200px;" />
            <p style="margin-top:12px; color:var(--frost-text-dim);" id="qrSerial"></p>
            <button class="btn-fms btn-primary-fms" onclick="printQR()" style="margin-top:10px;">
                <i class="fa-solid fa-print"></i> Print
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(id) { document.getElementById(id).classList.add('show'); }
        function closeModal(id) { document.getElementById(id).classList.remove('show'); }
        document.querySelectorAll('.fms-modal-overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('show'); }));

        function filterTable() {
            const q = document.getElementById('fridgeSearch').value.toLowerCase();
            document.querySelectorAll('#fridgeTable tbody tr').forEach(row => {
                row.style.display = (row.dataset.search || '').toLowerCase().includes(q) ? '' : 'none';
            });
        }

        function openQRModal(id, serial) {
            document.getElementById('qrImage').src = '/FaultTechnician/GenerateFridgeQRCode?id=' + id;
            document.getElementById('qrSerial').textContent = 'Fridge: ' + serial;
            openModal('qrModal');
        }

        function printQR() {
            var img = document.getElementById('qrImage');
            var win = window.open('', '_blank');
            win.document.write('<html><head><title>QR Code</title></head><body style="text-align:center;">' +
                '<img src="' + img.src + '" style="width:250px; height:250px;" />' +
                '</body></html>');
            win.document.close();
            win.print();
        }
    </script>
}