@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Fridge History";
    var fridge = ViewBag.Fridge as FridgeManagement.Models.Fridge;
    var timeline = ViewBag.Timeline as List<dynamic>;
    var timelineCount = (int)ViewBag.TimelineCount;
}

<div class="page-header">
    <div>
        <h1>Fridge History</h1>
        <p>@fridge?.SerialNumber – @fridge?.Model</p>
    </div>
    <a asp-action="DashBoard" class="btn-fms btn-ghost-fms">
        <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
    </a>
</div>

<!-- Fridge details card -->
<div class="fms-card" style="margin-bottom:20px;">
    <div class="fms-card-header">
        <div class="fms-card-title">Fridge Information</div>
    </div>
    <div style="padding:20px; display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
        <div><strong>Serial Number:</strong> @fridge?.SerialNumber</div>
        <div><strong>Brand:</strong> @fridge?.Brand</div>
        <div><strong>Model:</strong> @fridge?.Model</div>
        <div><strong>Purchase Date:</strong> @(fridge?.PurchaseDate?.ToString("yyyy-MM-dd") ?? "N/A")</div>
        <div><strong>Warranty Expiry:</strong> @(fridge?.WarrantyExpiryDate?.ToString("yyyy-MM-dd") ?? "N/A")</div>
        <div><strong>Status:</strong> @fridge?.Status</div>
        <div><strong>Supplier:</strong> @(fridge?.Supplier?.Name ?? "N/A")</div>
    </div>
</div>

<!-- WARRANTY CARD -->
<div class="fms-card" style="margin-bottom:20px;">
    <div class="fms-card-header">
        <div class="fms-card-title"><i class="fa-solid fa-shield-halved"></i> Warranty</div>
    </div>
    <div style="padding:20px; display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
        @{
            var warrantyExpiry = fridge?.WarrantyExpiryDate;
            var supplier = fridge?.Supplier?.Name ?? "Unknown";
            bool isUnderWarranty = warrantyExpiry.HasValue && warrantyExpiry.Value > DateTime.Now;
            string warrantyStatus = isUnderWarranty ? "Under Warranty" : "Expired";
            string warrantyColor = isUnderWarranty ? "green" : "red";
            string coveredRepairs = "Compressor, thermostat, door seal, gas recharge"; // placeholder
        }
        <div><strong>Status:</strong> <span class="fms-badge @warrantyColor">@warrantyStatus</span></div>
        <div><strong>Expiry Date:</strong> @(warrantyExpiry?.ToString("yyyy-MM-dd") ?? "N/A")</div>
        <div><strong>Supplier:</strong> @supplier</div>
        <div><strong>Covered Repairs:</strong> @coveredRepairs</div>
        @if (!isUnderWarranty)
        {
            <div style="grid-column:span 2; margin-top:10px; padding:10px; background:rgba(240,99,122,0.1); border:1px solid var(--danger); border-radius:8px;">
                <i class="fa-solid fa-triangle-exclamation" style="color:var(--danger);"></i>
                <strong style="color:var(--danger);"> Out of Warranty</strong> – repairs may incur charges.
            </div>
        }
    </div>
</div>

<!-- Complete History Timeline -->
<div class="fms-card">
    <div class="fms-card-header">
        <div class="fms-card-title">Complete History (@timelineCount events)</div>
    </div>
    <div class="timeline-container">
        @if (timeline != null && timeline.Any())
        {
            foreach (var evt in timeline)
            {
                var date = (DateTime)evt.Date;
                var type = (string)evt.Type;
                var desc = (string)evt.Description;
                var icon = (string)evt.Icon;
                var color = (string)evt.Color;
                <div class="timeline-item">
                    <div class="timeline-icon" style="background-color:@color;">
                        <i class="fa-solid @icon"></i>
                    </div>
                    <div class="timeline-content">
                        <div class="timeline-date">@date.ToString("yyyy-MM-dd HH:mm")</div>
                        <div class="timeline-type">@type</div>
                        <div class="timeline-desc">@desc</div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="padding:20px; text-align:center; color:var(--muted);">
                <i class="fa-solid fa-clock-rotate-left" style="font-size:36px; margin-bottom:10px;"></i>
                <p>No events recorded for this fridge yet.</p>
            </div>
        }
    </div>
</div>

<!-- Note about parts replaced -->
<div class="fms-card" style="margin-top:20px;">
    <div class="fms-card-header">
        <div class="fms-card-title">Parts Replaced</div>
    </div>
    <div style="padding:20px; text-align:center; color:var(--muted);">
        <i class="fa-solid fa-gear" style="font-size:36px; margin-bottom:10px;"></i>
        <p>Parts replacement tracking is not yet implemented.</p>
    </div>
</div>

<style>
    .timeline-container {
        padding: 20px 20px 20px 40px;
        position: relative;
    }

        .timeline-container::before {
            content: '';
            position: absolute;
            left: 28px;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(to bottom, var(--ice), var(--panel-border));
            border-radius: 2px;
        }

    .timeline-item {
        display: flex;
        gap: 20px;
        margin-bottom: 25px;
        position: relative;
    }

    .timeline-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: white;
        font-size: 14px;
        box-shadow: 0 0 0 4px var(--panel-bg);
        z-index: 1;
    }

    .timeline-content {
        background: var(--panel-bg);
        border: 1px solid var(--panel-border);
        border-radius: 10px;
        padding: 12px 16px;
        flex: 1;
    }

    .timeline-date {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 4px;
    }

    .timeline-type {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .timeline-desc {
        font-size: 0.85rem;
        color: var(--text-muted);
    }
</style>