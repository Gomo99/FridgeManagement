@model FridgeManagement.Models.PurchaseRequest
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Request Details";
}
<div class="page-header">
    <h1>Purchase Request #@Model.Id</h1>
    <a asp-action="PurchaseRequests" class="btn-fms btn-ghost-fms">Back</a>
</div>
<div class="fms-card" style="max-width:600px;">
    <dl class="row" style="padding:16px;">
        <dt class="col-sm-4">Requester</dt>
        <dd class="col-sm-8">@Model.RequestedBy?.FullName</dd>
        <dt class="col-sm-4">Date</dt>
        <dd class="col-sm-8">@Model.RequestDate.ToString("yyyy-MM-dd")</dd>
        <dt class="col-sm-4">Reason</dt>
        <dd class="col-sm-8">@Model.Reason</dd>
        <dt class="col-sm-4">Quantity</dt>
        <dd class="col-sm-8">@Model.QuantityRequested</dd>
        <dt class="col-sm-4">Status</dt>
        <dd class="col-sm-8">@Model.Status</dd>
    </dl>
</div>