@model List<FridgeManagement.Models.FaultReport>
@{
    var faults = Model;
}

<div class="fms-card">
    <div class="fms-card-header">
        <div class="fms-card-title">Fault History (@faults.Count)</div>
    </div>
    @if (faults.Any())
    {
        <table class="fms-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Technician</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in faults)
                {
                    <tr>
                        <td>@f.ReportedDate.ToString("yyyy-MM-dd")</td>
                        <td>@f.Description</td>
                        <td>@f.AssignedTechnician?.FullName</td>
                        <td>@f.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="padding:20px;"><em>No faults reported for this fridge.</em></div>
    }
</div>