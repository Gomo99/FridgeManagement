@{
    var upcoming = (Model as dynamic).Item1 as List<FridgeManagement.Models.MaintenanceSchedule>;
    var completed = (Model as dynamic).Item2 as List<FridgeManagement.Models.MaintenanceLog>;
}

<div class="fms-card" style="margin-bottom:20px;">
    <div class="fms-card-header">
        <div class="fms-card-title">Upcoming Maintenance (@upcoming.Count)</div>
    </div>
    @if (upcoming.Any())
    {
        <table class="fms-table">
            <thead>
                <tr>
                    <th>Scheduled Date</th>
                    <th>Technician</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in upcoming)
                {
                    <tr>
                        <td>@s.ScheduledDate.ToString("yyyy-MM-dd")</td>
                        <td>@s.AssignedTechnician?.FullName</td>
                        <td>@s.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="padding:20px;"><em>No upcoming maintenance.</em></div>
    }
</div>

<div class="fms-card">
    <div class="fms-card-header">
        <div class="fms-card-title">Completed Maintenance (@completed.Count)</div>
    </div>
    @if (completed.Any())
    {
        <table class="fms-table">
            <thead>
                <tr>
                    <th>Completed Date</th>
                    <th>Technician</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in completed)
                {
                    <tr>
                        <td>@l.CompletedDate?.ToString("yyyy-MM-dd")</td>
                        <td>@l.Technician?.FullName</td>
                        <td>@l.ServiceNotes</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="padding:20px;"><em>No completed maintenance yet.</em></div>
    }
</div>