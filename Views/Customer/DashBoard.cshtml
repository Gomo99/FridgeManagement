@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Customer Dashboard";
    var customer = ViewBag.Customer as FridgeManagement.Models.Customer;
    var allocatedFridges = ViewBag.AllocatedFridges as List<FridgeManagement.Models.FridgeAllocation>;
    var recentFaults = ViewBag.RecentFaults as List<FridgeManagement.Models.FaultReport>;
    var fridgeListJson = ViewBag.FridgeListJson as string ?? "[]";

    var allocatedFridgesCount = (int)ViewBag.AllocatedFridgesCount;
    var pendingFaultsCount = (int)ViewBag.PendingFaults;
    var openFaultsCount = (int)ViewBag.OpenFaults;
    var completedRepairsCount = (int)ViewBag.CompletedRepairs;
    var upcomingMaintenanceCount = (int)ViewBag.UpcomingMaintenance;
    var pendingRequestsCount = (int)ViewBag.PendingRequests;
    var approvedRequestsCount = (int)ViewBag.ApprovedRequests;
    var completedServicesCount = (int)ViewBag.CompletedServices;
}

<div class="page-header">
    <div>
        <h1>Welcome, @customer?.Name</h1>
        <p>Your fridge management portal</p>
    </div>
</div>

<!-- ==================== STATISTICS CARDS ==================== -->
<div class="grid-4" style="margin-bottom:28px;">
    <div class="stat-card">
        <div class="stat-icon teal"><i class="fa-solid fa-snowflake"></i></div>
        <div>
            <div class="stat-value">@allocatedFridgesCount</div>
            <div class="stat-label">Allocated Fridges</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange"><i class="fa-solid fa-clock"></i></div>
        <div>
            <div class="stat-value">@pendingFaultsCount</div>
            <div class="stat-label">Pending Faults</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red"><i class="fa-solid fa-wrench"></i></div>
        <div>
            <div class="stat-value">@openFaultsCount</div>
            <div class="stat-label">Open Faults</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-circle-check"></i></div>
        <div>
            <div class="stat-value">@completedRepairsCount</div>
            <div class="stat-label">Completed Repairs</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon teal"><i class="fa-solid fa-calendar-check"></i></div>
        <div>
            <div class="stat-value">@upcomingMaintenanceCount</div>
            <div class="stat-label">Upcoming Maintenance</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange"><i class="fa-solid fa-hourglass-half"></i></div>
        <div>
            <div class="stat-value">@pendingRequestsCount</div>
            <div class="stat-label">Pending Requests</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fa-solid fa-thumbs-up"></i></div>
        <div>
            <div class="stat-value">@approvedRequestsCount</div>
            <div class="stat-label">Approved Requests</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-gears"></i></div>
        <div>
            <div class="stat-value">@completedServicesCount</div>
            <div class="stat-label">Completed Services</div>
        </div>
    </div>
</div>

<!-- ==================== QUICK ACTIONS ==================== -->
<div class="fms-card" style="margin-bottom:28px;">
    <div class="fms-card-header"><div class="fms-card-title">Quick Actions</div></div>
    <div class="grid-2" style="gap:12px; padding:16px;">
        <a asp-action="MyFridges" class="btn-fms btn-primary-fms w-100">My Fridges</a>
        <a asp-action="MyFaults" class="btn-fms btn-warning-fms w-100">My Fault Reports</a>
        <a asp-action="MyFridgeRequests" class="btn-fms btn-info-fms w-100">My Fridge Requests</a>
        <button onclick="openReportFaultModal()" class="btn-fms btn-danger-fms">Report a Fault</button>
        <button onclick="openRequestFridgeModal()" class="btn-fms btn-success-fms">Request a Fridge</button>
        <a asp-action="UpcomingMaintenance" class="btn-fms btn-ghost-fms">Upcoming Maintenance</a>
        <a asp-action="MyProfile" class="btn-fms btn-ghost-fms">
            <i class="fa-solid fa-user-pen"></i> Edit Profile
        </a>
        <a asp-action="BusinessInfo" class="btn-fms btn-ghost-fms">
            <i class="fa-solid fa-building"></i> Business Info
        </a>
    </div>
</div>

<!-- ==================== RECENT FAULTS (optional) ==================== -->
@if (recentFaults != null && recentFaults.Any())
{
    <div class="fms-card" style="margin-bottom:28px;">
        <div class="fms-card-header">
            <div class="fms-card-title">Recent Faults</div>
        </div>
        <table class="fms-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Fridge</th>
                    <th>Description</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fault in recentFaults)
                {
                    <tr>
                        <td>@fault.ReportedDate.ToString("yyyy-MM-dd")</td>
                        <td>@fault.Fridge?.SerialNumber</td>
                        <td>@fault.Description</td>
                        <td>@fault.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- ═══════ MODALS (unchanged) ═══════ -->
<div class="fms-modal-overlay" id="reportFaultModal">
    <div class="fms-modal">
        <div class="fms-modal-header">
            <div class="fms-modal-title"><i class="fa-solid fa-triangle-exclamation" style="color:var(--danger);"></i> Report Fault</div>
            <button class="fms-modal-close" onclick="closeModal('reportFaultModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form asp-action="ReportFault" method="post" id="reportFaultForm">
            @Html.AntiForgeryToken()
            <div class="fms-form-group">
                <label for="FridgeId">Fridge</label>
                <select name="FridgeId" id="faultFridgeSelect" class="fms-select" required></select>
            </div>
            <div class="fms-form-group">
                <label for="Description">Description</label>
                <textarea name="Description" class="fms-textarea" rows="3" required></textarea>
            </div>

            <!-- Emergency Fault Checkbox -->
            <div class="fms-form-group" style="margin-bottom:12px;">
                <div class="fms-checkbox-wrapper">
                    <input type="checkbox" id="isCritical" name="isCritical" value="true" onchange="toggleEmergency(this)">
                    <label for="isCritical" class="fms-label" style="display:inline; margin-left:6px;">
                        <i class="fa-solid fa-triangle-exclamation" style="color:var(--danger);"></i>
                        <strong>Emergency Fault (Critical)</strong>
                    </label>
                </div>
                <small style="color:var(--text-muted);">Check this if the fridge is completely broken and needs immediate attention.</small>
            </div>

            <!-- Priority Dropdown (hidden when emergency is checked) -->
            <div class="fms-form-group" id="priorityGroup">
                <label for="Priority">Priority</label>
                <select name="Priority" class="fms-select" asp-items="Html.GetEnumSelectList<FridgeManagement.AppStatus.FaultPriority>()">
                    <option value="">-- Select --</option>
                </select>
            </div>

            <div style="display:flex; gap:10px; justify-content:flex-end;">
                <button type="button" class="btn-fms btn-ghost-fms" onclick="closeModal('reportFaultModal')">Cancel</button>
                <button type="submit" class="btn-fms btn-danger-fms">Submit Fault</button>
            </div>
        </form>
    </div>
</div>

<!-- ═══════════════ CHARTS SECTION ═══════════════ -->
<div class="fms-card" style="margin-bottom:28px;">
    <div class="fms-card-header">
        <div class="fms-card-title">Performance Overview</div>
    </div>
    <div style="padding:16px; display:grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px;">
        <div>
            <h4 style="margin-bottom:8px;">Faults This Year</h4>
            <canvas id="chartFaultsYear" height="200"></canvas>
        </div>
        <div>
            <h4 style="margin-bottom:8px;">Maintenance History</h4>
            <canvas id="chartMaintHistory" height="200"></canvas>
        </div>
        <div>
            <h4 style="margin-bottom:8px;">Repairs per Month</h4>
            <canvas id="chartRepairsMonth" height="200"></canvas>
        </div>
        <div>
            <h4 style="margin-bottom:8px;">Request Status</h4>
            <canvas id="chartRequestStatus" height="200"></canvas>
        </div>
    </div>
</div>


<!-- ═══════════════ MAINTENANCE CALENDAR ═══════════════ -->
<div class="fms-card" style="margin-bottom:28px;">
    <div class="fms-card-header">
        <div class="fms-card-title"><i class="fa-solid fa-calendar-days"></i> Maintenance Calendar</div>
    </div>
    <div id="calendar" style="padding: 0 16px 16px;"></div>
</div>



@* Request Fridge Modal *@
<div class="fms-modal-overlay" id="requestFridgeModal">
    <div class="fms-modal">
        <div class="fms-modal-header">
            <div class="fms-modal-title"><i class="fa-solid fa-plus" style="color:var(--success);"></i> Request a Fridge</div>
            <button class="fms-modal-close" onclick="closeModal('requestFridgeModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form asp-action="RequestFridge" method="post">
            @Html.AntiForgeryToken()
            <div class="fms-form-group">
                <label for="Reason">Reason</label>
                <input type="text" name="Reason" class="fms-input" placeholder="Why do you need a new fridge?" required />
            </div>
            <div class="fms-form-group">
                <label for="QuantityRequested">Quantity</label>
                <input type="number" name="QuantityRequested" class="fms-input" min="1" value="1" />
            </div>
            <div style="display:flex; gap:10px; justify-content:flex-end;">
                <button type="button" class="btn-fms btn-ghost-fms" onclick="closeModal('requestFridgeModal')">Cancel</button>
                <button type="submit" class="btn-fms btn-success-fms">Submit Request</button>
            </div>
        </form>
    </div>
</div>


@* ═══════════════ SERVICE REMINDER ═══════════════ *@
@{
    var tomorrowMaintenance = ViewBag.TomorrowMaintenance as FridgeManagement.Models.MaintenanceSchedule;
}
@if (tomorrowMaintenance != null)
{
    <div class="fms-card" style="margin-bottom:28px; border-left: 4px solid var(--ice);">
        <div style="padding:20px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:15px;">
            <div>
                <h3 style="margin:0; color:var(--ice);"><i class="fa-solid fa-calendar-check"></i> Upcoming Maintenance Tomorrow</h3>
                <p style="margin:8px 0 0; color:var(--text-primary);">
                    <strong>Fridge:</strong> @tomorrowMaintenance.Fridge?.SerialNumber<br />
                    <strong>Technician:</strong> @(tomorrowMaintenance.AssignedTechnician?.FullName ?? "Not assigned")<br />
                    <strong>Scheduled Time:</strong> @tomorrowMaintenance.ScheduledDate.ToString("HH:mm")<br />
                    <strong>Location:</strong> @(ViewBag.Customer?.Address ?? "Your premises")
                </p>
            </div>
            <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
                @if (!tomorrowMaintenance.IsConfirmed)
                {
                    <form asp-action="ConfirmMaintenanceAttendance" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="scheduleId" value="@tomorrowMaintenance.Id" />
                        <button type="submit" class="btn-fms btn-success-fms" style="white-space:nowrap;">
                            <i class="fa-solid fa-circle-check"></i> Confirm
                        </button>
                    </form>
                }
                else
                {
                    <span class="fms-badge green" style="font-size:0.9rem; padding:8px 14px;">
                        <i class="fa-solid fa-check"></i> Attendance Confirmed
                    </span>
                }
                <button type="button" class="btn-fms btn-primary-fms" onclick="openRescheduleModal(@tomorrowMaintenance.Id, '@tomorrowMaintenance.ScheduledDate.ToString("yyyy-MM-dd")', '@tomorrowMaintenance.ScheduledDate.ToString("HH:mm")')">
                    <i class="fa-solid fa-calendar-alt"></i> Reschedule
                </button>
                <form asp-action="CancelMaintenanceVisit" method="post" style="display:inline;"
                      onsubmit="return confirm('Cancel this maintenance visit? The schedule will be removed.')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="scheduleId" value="@tomorrowMaintenance.Id" />
                    <button type="submit" class="btn-fms btn-danger-fms">
                        <i class="fa-solid fa-times"></i> Cancel
                    </button>
                </form>
            </div>
        </div>
    </div>
}


@* ═══════════════ RESCHEDULE MAINTENANCE MODAL ═══════════════ *@
<div class="fms-modal-overlay" id="rescheduleModal">
    <div class="fms-modal" style="max-width:450px;">
        <div class="fms-modal-header">
            <div class="fms-modal-title"><i class="fa-solid fa-calendar-alt" style="color:var(--ice); margin-right:10px;"></i>Reschedule Maintenance</div>
            <button class="fms-modal-close" onclick="closeModal('rescheduleModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <form asp-action="RescheduleMaintenance" method="post" style="padding:20px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="scheduleId" id="rescheduleScheduleId" />

            <div class="fms-form-group">
                <label class="fms-label">Quick Options</label>
                <div style="display:flex; flex-wrap:wrap; gap:8px;">
                    <button type="button" class="btn-fms btn-ghost-fms btn-sm-fms" onclick="setQuickReschedule('Tomorrow')">Tomorrow</button>
                    <button type="button" class="btn-fms btn-ghost-fms btn-sm-fms" onclick="setQuickReschedule('Friday')">This Friday</button>
                    <button type="button" class="btn-fms btn-ghost-fms btn-sm-fms" onclick="setQuickReschedule('NextWeek')">Next Week</button>
                    <button type="button" class="btn-fms btn-ghost-fms btn-sm-fms" onclick="setQuickReschedule('Morning')">Morning (09:00)</button>
                    <button type="button" class="btn-fms btn-ghost-fms btn-sm-fms" onclick="setQuickReschedule('Afternoon')">Afternoon (14:00)</button>
                </div>
                <input type="hidden" name="quickOption" id="quickOption" value="" />
            </div>

            <div class="fms-form-group">
                <label class="fms-label">Or choose custom date & time</label>
                <div class="grid-2">
                    <input type="date" name="customDate" id="customDate" class="fms-input" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <input type="time" name="customTime" id="customTime" class="fms-input" />
                </div>
            </div>

            <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:12px;">
                <button type="button" class="btn-fms btn-ghost-fms" onclick="closeModal('rescheduleModal')">Cancel</button>
                <button type="submit" class="btn-fms btn-primary-fms">Save New Schedule</button>
            </div>
        </form>
    </div>
</div>




@section Scripts {
    <script>

        <!-- FullCalendar CSS & JS -->
        <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet" />
        <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
            var customerFridges = @Html.Raw(fridgeListJson);

            function openModal(id) { document.getElementById(id).classList.add('show'); }
            function closeModal(id) { document.getElementById(id).classList.remove('show'); }
            document.querySelectorAll('.fms-modal-overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('show'); }));

            function openReportFaultModal(selectedFridgeId = null) {
                var select = document.getElementById('faultFridgeSelect');
                select.innerHTML = '<option value="">-- Select fridge --</option>';
                customerFridges.forEach(f => {
                    select.innerHTML += `<option value="${f.id}" ${selectedFridgeId == f.id ? 'selected' : ''}>${f.serial}</option>`;
                });
                openModal('reportFaultModal');
            }

            function openRequestFridgeModal() {
                openModal('requestFridgeModal');
            }



        var customerFridges = @Html.Raw(fridgeListJson);

        function openModal(id) { document.getElementById(id).classList.add('show'); }
        function closeModal(id) { document.getElementById(id).classList.remove('show'); }
        document.querySelectorAll('.fms-modal-overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('show'); }));

        function openReportFaultModal(selectedFridgeId = null) {
            var select = document.getElementById('faultFridgeSelect');
            select.innerHTML = '<option value="">-- Select fridge --</option>';
            customerFridges.forEach(f => {
                select.innerHTML += `<option value="${f.id}" ${selectedFridgeId == f.id ? 'selected' : ''}>${f.serial}</option>`;
            });
            openModal('reportFaultModal');
        }

        function openRequestFridgeModal() {
            openModal('requestFridgeModal');
        }


       
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
        // ═══════ CHARTS ═══════
        const chartFontColor = getComputedStyle(document.documentElement).getPropertyValue('--text-primary').trim() || '#e0e0e0';
        const chartGridColor = 'rgba(150,210,230,0.15)';

        function makeBarChart(canvasId, labels, data, color) {
            new Chart(document.getElementById(canvasId), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: color,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { ticks: { color: chartFontColor }, grid: { color: chartGridColor } },
                        y: { beginAtZero: true, ticks: { precision: 0, color: chartFontColor }, grid: { color: chartGridColor } }
                    }
                }
            });
        }

        // 1. Faults This Year
        makeBarChart('chartFaultsYear',
            @Html.Raw(ViewBag.FaultsYearLabels ?? "[]"),
            @Html.Raw(ViewBag.FaultsYearData ?? "[]"),
            '#F0637A'
        );

        // 2. Maintenance History
        makeBarChart('chartMaintHistory',
            @Html.Raw(ViewBag.MaintHistoryLabels ?? "[]"),
            @Html.Raw(ViewBag.MaintHistoryData ?? "[]"),
            '#5FD4E0'
        );

        // 3. Repairs per Month
        makeBarChart('chartRepairsMonth',
            @Html.Raw(ViewBag.RepairsMonthLabels ?? "[]"),
            @Html.Raw(ViewBag.RepairsMonthData ?? "[]"),
            '#3ECF8E'
        );

        // 4. Request Status (doughnut chart)
        new Chart(document.getElementById('chartRequestStatus'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(ViewBag.RequestStatusLabels ?? "[]"),
                datasets: [{
                    data: @Html.Raw(ViewBag.RequestStatusData ?? "[]"),
                    backgroundColor: ['#5FD4E0','#F5A623','#F0637A','#3ECF8E','#8FAEBE'],
                    borderColor: 'rgba(0,0,0,0.2)'
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { labels: { color: chartFontColor } }
                }
            }
        });


            function toggleEmergency(checkbox) {
            const priorityGroup = document.getElementById('priorityGroup');
            if (checkbox.checked) {
                priorityGroup.style.display = 'none';
                // Set a hidden field for Priority to ensure model binding, but it will be overridden in controller
                document.querySelector('select[name="Priority"]').value = '';
            } else {
                priorityGroup.style.display = '';
            }
        }
            function openRescheduleModal(scheduleId, currentDate, currentTime) {
        document.getElementById('rescheduleScheduleId').value = scheduleId;
        document.getElementById('customDate').value = currentDate;
        document.getElementById('customTime').value = currentTime;
        document.getElementById('quickOption').value = '';
        openModal('rescheduleModal');
    }

    function setQuickReschedule(option) {
        document.getElementById('quickOption').value = option;
        // Clear custom fields
        document.getElementById('customDate').value = '';
        document.getElementById('customTime').value = '';
    }
    </script>
}


