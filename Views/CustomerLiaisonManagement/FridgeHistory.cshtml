@model List<FridgeManagement.Models.FridgeAllocation>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Fridge Allocation History";
    var fridge = ViewBag.Fridge as FridgeManagement.Models.Fridge;
}

<div class="page-header">
    <div>
        <h1>Allocation History</h1>
        <p>Fridge <strong>@fridge?.SerialNumber</strong> (@fridge?.Model)</p>
    </div>
    <a asp-action="Allocations" class="btn-fms btn-ghost-fms">
        <i class="fa-solid fa-arrow-left"></i> Back to Allocations
    </a>
</div>

@if (!Model.Any())
{
    <div class="fms-card">
        <div class="fms-card-header"><div class="fms-card-title">No allocation records</div></div>
        <div style="padding:20px;"><em>This fridge has never been allocated.</em></div>
    </div>
}
else
{
    <div class="fms-card">
        <div class="fms-card-header">
            <div class="fms-card-title">Fridge Lifecycle</div>
        </div>
        <div class="timeline-container">
            @foreach (var alloc in Model.OrderBy(a => a.AllocationDate))
            {
                var isReturn = alloc.Status == AllocationStatus.Returned;
                var isActive = alloc.Status == AllocationStatus.Active;
                // Determine event type and color
                string type, icon, color;
                if (isReturn)
                {
                    type = "Returned";
                    icon = "fa-rotate-left";
                    color = "#F5A623";
                }
                else if (isActive)
                {
                    type = "Allocated";
                    icon = "fa-hand-holding";
                    color = "#3ECF8E";
                }
                else
                {
                    type = alloc.Status.ToString();
                    icon = "fa-info-circle";
                    color = "#8FAEBE";
                }

                <div class="timeline-item">
                    <div class="timeline-icon" style="background-color:@color;">
                        <i class="fa-solid @icon"></i>
                    </div>
                    <div class="timeline-content">
                        <div class="timeline-date">@alloc.AllocationDate.ToString("yyyy-MM-dd")</div>
                        <div class="timeline-type">@type</div>
                        <div class="timeline-desc">
                            <strong>Customer:</strong> @alloc.Customer?.Name<br />
                            <strong>Location:</strong> @(alloc.Customer?.Address ?? "N/A")<br />
                            @if (alloc.ReturnDate.HasValue)
                            {
                                <strong>Returned on:</strong> 
                                @alloc.ReturnDate.Value.ToString("yyyy-MM-dd")
                            }
                        </div>
                    </div>
                </div>

                // If this allocation is still active and it's the last one, show a placeholder for future
                if (isActive && alloc == Model.OrderBy(a => a.AllocationDate).Last())
                {
                    <div class="timeline-item">
                        <div class="timeline-icon" style="background-color:#5FD4E0;">
                            <i class="fa-solid fa-arrow-right"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-type">Currently Active</div>
                            <div class="timeline-desc">Fridge is still allocated to this customer.</div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

<style>
    .timeline-container {
        padding: 20px 20px 20px 40px;
        position: relative;
    }

        .timeline-container::before {
            content: '';
            position: absolute;
            left: 28px;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(to bottom, var(--ice), var(--panel-border));
            border-radius: 2px;
        }

    .timeline-item {
        display: flex;
        gap: 20px;
        margin-bottom: 25px;
        position: relative;
    }

    .timeline-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: white;
        font-size: 14px;
        box-shadow: 0 0 0 4px var(--panel-bg);
        z-index: 1;
    }

    .timeline-content {
        background: var(--panel-bg);
        border: 1px solid var(--panel-border);
        border-radius: 10px;
        padding: 12px 16px;
        flex: 1;
    }

    .timeline-date {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 4px;
    }

    .timeline-type {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .timeline-desc {
        font-size: 0.85rem;
        color: var(--text-muted);
    }
</style>