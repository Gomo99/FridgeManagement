@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Allocation Calendar";
}

<div class="page-header">
    <div>
        <h1>Allocation Calendar</h1>
        <p>Deliveries, returns, and customer visits</p>
    </div>
    <a asp-action="DashBoard" class="btn-fms btn-ghost-fms">
        <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
    </a>
</div>

<div class="fms-card">
    <div class="fms-card-header">
        <div class="fms-card-title"><i class="fa-solid fa-calendar-days"></i> Schedule Overview</div>
    </div>
    <div id="calendar" style="padding: 16px;"></div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('calendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,listWeek'
                },
                events: @Html.Raw(ViewBag.CalendarEvents),
                height: 'auto',
                themeSystem: 'standard',
                eventTimeFormat: { hour: '2-digit', minute: '2-digit' },
                dayMaxEvents: true
            });
            calendar.render();
        });
    </script>
    <style>
        .fc {
            color: var(--text-primary);
            background: transparent;
        }

            .fc .fc-toolbar-title {
                color: var(--text-primary);
            }

            .fc .fc-button {
                background: var(--panel-bg);
                border-color: var(--panel-border);
                color: var(--text-primary);
            }

                .fc .fc-button:hover {
                    background: var(--ice);
                    color: #fff;
                }

            .fc .fc-daygrid-day-number {
                color: var(--text-muted);
            }

            .fc .fc-col-header-cell-cushion {
                color: var(--text-muted);
            }

        .fc-theme-standard td, .fc-theme-standard th {
            border-color: var(--panel-border);
        }
    </style>
}