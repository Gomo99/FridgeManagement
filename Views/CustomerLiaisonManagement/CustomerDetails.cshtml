@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Customer Profile";
    var customer = ViewBag.Customer as FridgeManagement.Models.Customer;
    var allocatedFridges = ViewBag.AllocatedFridges as List<FridgeManagement.Models.FridgeAllocation>;
    var allocationHistory = ViewBag.AllocationHistory as List<FridgeManagement.Models.FridgeAllocation>;
    var faultHistory = ViewBag.FaultHistory as List<FridgeManagement.Models.FaultReport>;
    var maintenanceSchedules = ViewBag.MaintenanceSchedules as List<FridgeManagement.Models.MaintenanceSchedule>;
    var fridgeRequests = ViewBag.FridgeRequests as List<FridgeManagement.Models.FridgeRequest>;
    var timeline = ViewBag.Timeline as List<dynamic>;
}

<div class="page-header">
    <div>
        <h1>@customer?.Name</h1>
        <p>Customer Profile</p>
    </div>
    <a asp-action="Customers" class="btn-fms btn-ghost-fms">
        <i class="fa-solid fa-arrow-left"></i> Back to Customers
    </a>
</div>

<!-- Tabs Navigation -->
<div class="fridge-tabs">
    <button class="fridge-tab active" data-tab="overview">Overview</button>
    <button class="fridge-tab" data-tab="fridges">Fridges</button>
    <button class="fridge-tab" data-tab="faults">Faults</button>
    <button class="fridge-tab" data-tab="maintenance">Maintenance</button>
    <button class="fridge-tab" data-tab="requests">Requests</button>
    <button class="fridge-tab" data-tab="documents">Documents</button>
    <button class="fridge-tab" data-tab="timeline">Timeline</button>
</div>

<!-- Tab Panels -->
<div id="tab-overview" class="fridge-tab-panel active">
    @await Html.PartialAsync("_CustomerProfileOverview", customer)
</div>
<div id="tab-fridges" class="fridge-tab-panel" style="display:none;">
    @await Html.PartialAsync("_CustomerProfileFridges", (allocatedFridges, allocationHistory))
</div>
<div id="tab-faults" class="fridge-tab-panel" style="display:none;">
    @await Html.PartialAsync("_CustomerProfileFaults", faultHistory)
</div>
<div id="tab-maintenance" class="fridge-tab-panel" style="display:none;">
    @await Html.PartialAsync("_CustomerProfileMaintenance", maintenanceSchedules)
</div>
<div id="tab-requests" class="fridge-tab-panel" style="display:none;">
    @await Html.PartialAsync("_CustomerProfileRequests", fridgeRequests)
</div>
<div id="tab-documents" class="fridge-tab-panel" style="display:none;">
    <div class="fms-card">
        <div class="fms-card-header">
            <div class="fms-card-title">Documents</div>
        </div>
        <div style="padding:20px; text-align:center;">
            <i class="fa-solid fa-file-pdf" style="font-size:48px; color:var(--muted); margin-bottom:10px;"></i>
            <p><em>No documents available.</em></p>
        </div>
    </div>
</div>
<div id="tab-timeline" class="fridge-tab-panel" style="display:none;">
    @await Html.PartialAsync("_CustomerProfileTimeline", timeline)
</div>


<a asp-action="CustomerNotes" asp-route-id="@customer.Id" class="btn-fms btn-ghost-fms">
    <i class="fa-solid fa-note-sticky"></i> Notes
</a>

@section Scripts {
    <script>
        document.querySelectorAll('.fridge-tab').forEach(tab => {
            tab.addEventListener('click', function () {
                document.querySelectorAll('.fridge-tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.fridge-tab-panel').forEach(p => p.style.display = 'none');
                this.classList.add('active');
                document.getElementById('tab-' + this.dataset.tab).style.display = '';
            });
        });
    </script>
    <style>
        .fridge-tabs {
            display: flex;
            gap: 2px;
            margin-bottom: 20px;
            border-bottom: 2px solid var(--panel-border);
        }

        .fridge-tab {
            background: none;
            border: none;
            padding: 12px 20px;
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--text-muted);
            cursor: pointer;
            position: relative;
            transition: color 0.2s;
        }

            .fridge-tab.active {
                color: var(--ice);
            }

                .fridge-tab.active::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    right: 0;
                    height: 2px;
                    background: var(--ice);
                }

            .fridge-tab:hover:not(.active) {
                color: var(--text-primary);
            }

        .fridge-tab-panel {
            animation: fadeIn 0.25s ease;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(5px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
}