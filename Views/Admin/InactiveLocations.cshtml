@model IEnumerable<FridgeManagement.Models.Location>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inactive Locations";
    ViewData["ActivePage"] = "Locations";
}

<div class="page-header">
    <div>
        <h1>Inactive Locations</h1>
        <p>Soft‑deleted locations</p>
    </div>
    <a asp-action="Locations" class="btn-fms btn-ghost-fms"><i class="fa-solid fa-arrow-left"></i> Back to Active</a>
</div>

<div class="fms-card">
    <div class="fms-card-header">
        <div class="fms-card-title">Deleted Locations</div>
        <div class="search-bar">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="inactSearch" placeholder="Search..." oninput="filterTable()" />
        </div>
    </div>
    <table class="fms-table" id="inactTable">
        <thead>
            <tr>
                <th>Name</th>
                <th>Address</th>
                <th>City</th>
                <th style="text-align:right;">Restore</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loc in Model)
            {
                <tr data-search="@loc.Name @loc.Address @loc.City">
                    <td>@loc.Name</td>
                    <td>@loc.Address</td>
                    <td>@loc.City</td>
                    <td style="text-align:right;">
                        <button class="btn-fms btn-success-fms btn-sm-fms"
                                onclick="openRestoreModal(@loc.Id, '@loc.Name.Replace("'", "\\'")')">
                            <i class="fa-solid fa-rotate-left"></i> Restore
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ═══════ RESTORE LOCATION MODAL ═══════ -->
<div class="fms-modal-overlay" id="restoreLocationModal">
    <div class="fms-modal" style="max-width:400px;">
        <div class="fms-modal-header">
            <div class="fms-modal-title"><i class="fa-solid fa-rotate-left" style="color:var(--success); margin-right:10px;"></i>Restore Location</div>
            <button class="fms-modal-close" onclick="closeModal('restoreLocationModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div style="padding:20px; text-align:center;">
            <p>Reactivate <strong id="restLocName"></strong>?</p>
            <div style="display:flex; gap:10px; justify-content:center; margin-top:20px;">
                <button type="button" class="btn-fms btn-ghost-fms" onclick="closeModal('restoreLocationModal')">Cancel</button>
                <form asp-action="RestoreLocation" method="post" id="restoreLocationForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="restLocId" />
                    <button type="submit" class="btn-fms btn-success-fms">Restore</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(id) { document.getElementById(id).classList.add('show'); }
        function closeModal(id) { document.getElementById(id).classList.remove('show'); }
        document.querySelectorAll('.fms-modal-overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('show'); }));

        function filterTable() {
            const q = document.getElementById('inactSearch').value.toLowerCase();
            document.querySelectorAll('#inactTable tbody tr').forEach(row => {
                row.style.display = (row.dataset.search || '').toLowerCase().includes(q) ? '' : 'none';
            });
        }

        function openRestoreModal(id, name) {
            document.getElementById('restLocId').value   = id;
            document.getElementById('restLocName').textContent = name;
            openModal('restoreLocationModal');
        }
    </script>
}