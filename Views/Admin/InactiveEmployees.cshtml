@model IEnumerable<FridgeManagement.Models.User>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inactive Employees";
    ViewData["ActivePage"] = "Employees";
}

<div class="page-header">
    <div>
        <h1>Inactive Employees</h1>
        <p>Soft‑deleted employee accounts</p>
    </div>
    <a asp-action="Employees" class="btn-fms btn-ghost-fms"><i class="fa-solid fa-arrow-left"></i> Back to Active</a>
</div>

<div class="fms-card">
    <div class="fms-card-header">
        <div class="fms-card-title">Inactive Accounts</div>
        <div class="search-bar">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="inactSearch" placeholder="Search..." oninput="filterTable()" />
        </div>
    </div>
    <table class="fms-table" id="inactTable">
        <thead>
            <tr>
                <th>Name</th>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th style="text-align:right;">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model)
            {
                <tr data-search="@emp.FullName @emp.Email @emp.Role">
                    <td>@emp.FullName</td>
                    <td>@emp.Username</td>
                    <td>@emp.Email</td>
                    <td>@emp.Role.ToString().Replace("_", " ")</td>
                    <td style="text-align:right;">
                        <button class="btn-fms btn-success-fms btn-sm-fms"
                                onclick="openRestoreModal(@emp.Id, '@emp.FullName.Replace("'", "\\'")')">
                            <i class="fa-solid fa-rotate-left"></i> Restore
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ═══════ RESTORE EMPLOYEE MODAL ═══════ -->
<div class="fms-modal-overlay" id="restoreEmployeeModal">
    <div class="fms-modal" style="max-width:400px;">
        <div class="fms-modal-header">
            <div class="fms-modal-title"><i class="fa-solid fa-rotate-left" style="color:var(--success); margin-right:10px;"></i>Restore Employee</div>
            <button class="fms-modal-close" onclick="closeModal('restoreEmployeeModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div style="padding:20px; text-align:center;">
            <p style="color:var(--muted);">Reactivate <strong id="restEmpName"></strong>?</p>
            <div style="display:flex; gap:10px; justify-content:center; margin-top:20px;">
                <button type="button" class="btn-fms btn-ghost-fms" onclick="closeModal('restoreEmployeeModal')">Cancel</button>
                <form asp-action="RestoreEmployee" method="post" id="restoreEmployeeForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="restEmpId" />
                    <button type="submit" class="btn-fms btn-success-fms">Restore</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(id) { document.getElementById(id).classList.add('show'); }
        function closeModal(id) { document.getElementById(id).classList.remove('show'); }
        document.querySelectorAll('.fms-modal-overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('show'); }));

        function filterTable() {
            const q = document.getElementById('inactSearch').value.toLowerCase();
            document.querySelectorAll('#inactTable tbody tr').forEach(r => {
                r.style.display = (r.dataset.search||'').toLowerCase().includes(q) ? '' : 'none';
            });
        }

        function openRestoreModal(id, name) {
            document.getElementById('restEmpId').value   = id;
            document.getElementById('restEmpName').textContent = name;
            openModal('restoreEmployeeModal');
        }
    </script>
}