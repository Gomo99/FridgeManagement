@model IEnumerable<FridgeManagement.Models.Customer>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Inactive Customers";
    ViewData["ActivePage"] = "Customers";
}

<div class="page-header">
    <div>
        <h1>Inactive Customers</h1>
        <p>Soft‑deleted customers</p>
    </div>
    <a asp-action="Customers" class="btn-fms btn-ghost-fms"><i class="fa-solid fa-arrow-left"></i> Back to Active</a>
</div>

<div class="fms-card">
    <div class="fms-card-header">
        <div class="fms-card-title">Deleted Customers</div>
        <div class="search-bar">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="inactSearch" placeholder="Search..." oninput="filterTable()" />
        </div>
    </div>
    <table class="fms-table" id="inactTable">
        <thead>
            <tr>
                <th>Business Name</th>
                <th>Contact</th>
                <th>Phone</th>
                <th>Email</th>
                <th style="text-align:right;">Restore</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cust in Model)
            {
                <tr data-search="@cust.Name @cust.ContactPerson">
                    <td>@cust.Name</td>
                    <td>@cust.ContactPerson</td>
                    <td>@cust.PhoneNumber</td>
                    <td>@cust.Email</td>
                    <td style="text-align:right;">
                        <button class="btn-fms btn-success-fms btn-sm-fms"
                                onclick="openRestoreModal(@cust.Id, '@cust.Name.Replace("'", "\\'")')">
                            <i class="fa-solid fa-rotate-left"></i> Restore
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ═══════ RESTORE CUSTOMER MODAL ═══════ -->
<div class="fms-modal-overlay" id="restoreCustomerModal">
    <div class="fms-modal" style="max-width:400px;">
        <div class="fms-modal-header">
            <div class="fms-modal-title"><i class="fa-solid fa-rotate-left" style="color:var(--success); margin-right:10px;"></i>Restore Customer</div>
            <button class="fms-modal-close" onclick="closeModal('restoreCustomerModal')"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div style="padding:20px; text-align:center;">
            <p>Reactivate <strong id="restCustName"></strong>?</p>
            <div style="display:flex; gap:10px; justify-content:center; margin-top:20px;">
                <button type="button" class="btn-fms btn-ghost-fms" onclick="closeModal('restoreCustomerModal')">Cancel</button>
                <form asp-action="RestoreCustomer" method="post" id="restoreCustomerForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="restCustId" />
                    <button type="submit" class="btn-fms btn-success-fms">Restore</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(id) { document.getElementById(id).classList.add('show'); }
        function closeModal(id) { document.getElementById(id).classList.remove('show'); }
        document.querySelectorAll('.fms-modal-overlay').forEach(o => o.addEventListener('click', e => { if (e.target === o) o.classList.remove('show'); }));

        function filterTable() {
            const q = document.getElementById('inactSearch').value.toLowerCase();
            document.querySelectorAll('#inactTable tbody tr').forEach(r => {
                r.style.display = (r.dataset.search||'').toLowerCase().includes(q) ? '' : 'none';
            });
        }

        function openRestoreModal(id, name) {
            document.getElementById('restCustId').value   = id;
            document.getElementById('restCustName').textContent = name;
            openModal('restoreCustomerModal');
        }
    </script>
}