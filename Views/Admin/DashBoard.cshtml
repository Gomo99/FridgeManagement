@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
    ViewData["ActivePage"] = "Dashboard";

    /* These would normally come from ViewBag / ViewModel */
    var totalEmployees  = ViewBag.TotalEmployees  ?? 0;
    var totalCustomers  = ViewBag.TotalCustomers  ?? 0;
    var totalFridges    = ViewBag.TotalFridges    ?? 0;
    var allocatedFridges= ViewBag.AllocatedFridges?? 0;
    var totalSuppliers  = ViewBag.TotalSuppliers  ?? 0;
    var openFaults      = ViewBag.OpenFaults      ?? 0;
    var pendingServices = ViewBag.PendingServices ?? 0;
    var pendingOrders   = ViewBag.PendingOrders   ?? 0;
}

<!-- Stats Row -->
<div class="grid-4" style="margin-bottom:28px;">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fa-solid fa-users-gear"></i></div>
        <div>
            <div class="stat-value">@totalEmployees</div>
            <div class="stat-label">Total Employees</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-store"></i></div>
        <div>
            <div class="stat-value">@totalCustomers</div>
            <div class="stat-label">Customers</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon teal"><i class="fa-solid fa-snowflake"></i></div>
        <div>
            <div class="stat-value">@totalFridges</div>
            <div class="stat-label">Fridges in System</div>
            <div class="stat-change up">
                <i class="fa-solid fa-arrow-up"></i> @allocatedFridges allocated
            </div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <div>
            <div class="stat-value">@openFaults</div>
            <div class="stat-label">Open Fault Reports</div>
        </div>
    </div>
</div>

<!-- Second Row -->
<div class="grid-2" style="margin-bottom:28px;align-items:start;">
    <!-- Quick Links -->
    <div class="fms-card">
        <div class="fms-card-header">
            <div class="fms-card-title">Administration</div>
            <i class="fa-solid fa-shield-halved" style="color:var(--ice);"></i>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            @{
                var adminLinks = new[] {
                    ("fa-users-gear","Employees","AdminController","ManageEmployees","blue"),
                    ("fa-store","Customers","AdminController","ManageCustomers","green"),
                    ("fa-snowflake","Fridges","AdminController","ManageFridges","teal"),
                    ("fa-truck","Suppliers","AdminController","ManageSuppliers","amber"),
                    ("fa-location-dot","Locations","AdminController","ManageLocations","purple"),
                    ("fa-clipboard-check","Service Checks","AdminController","ManageCheckTypes","blue"),
                };
                foreach (var (icon, label, ctrl, action, color) in adminLinks)
                {
                    <a asp-controller="@ctrl" asp-action="@action"
                       style="display:flex;align-items:center;gap:10px;padding:14px;
                              background:var(--navy);border:1px solid rgba(14,165,233,.08);
                              border-radius:10px;text-decoration:none;transition:var(--transition);"
                       onmouseover="this.style.borderColor='rgba(14,165,233,.3)';this.style.background='var(--ice-dim)'"
                       onmouseout="this.style.borderColor='rgba(14,165,233,.08)';this.style.background='var(--navy)'">
                        <div class="stat-icon @color" style="width:36px;height:36px;font-size:14px;border-radius:8px;flex-shrink:0;">
                            <i class="fa-solid @icon"></i>
                        </div>
                        <div style="font-family:'Outfit',sans-serif;font-weight:600;font-size:13.5px;color:var(--white);">@label</div>
                    </a>
                }
            }
        </div>
    </div>

    <!-- System Status -->
    <div>
        <div class="fms-card" style="margin-bottom:18px;">
            <div class="fms-card-header">
                <div class="fms-card-title">System Overview</div>
            </div>
            @{
                var metrics = new[] {
                    ("Fridge Allocation Rate", allocatedFridges, totalFridges, "blue"),
                    ("Active Employees",        totalEmployees,  20,           "green"),
                };
                foreach (var (label, val, max, color) in metrics)
                {
                    var pct = max > 0 ? (int)(((double)val / max) * 100) : 0;
                    <div style="margin-bottom:18px;">
                        <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                            <span style="font-size:13.5px;color:var(--muted);">@label</span>
                            <span style="font-size:13.5px;font-weight:600;color:var(--white);">@val / @max</span>
                        </div>
                        <div class="fms-progress"><div class="fms-progress-bar" style="width:@pct%;"></div></div>
                    </div>
                }
            }
            <div style="display:flex;gap:18px;margin-top:8px;">
                <div style="flex:1;text-align:center;padding:14px;background:var(--navy);border-radius:10px;">
                    <div style="font-size:20px;font-weight:800;font-family:'Outfit',sans-serif;color:var(--warning);">@pendingOrders</div>
                    <div style="font-size:12px;color:var(--muted);">Pending Orders</div>
                </div>
                <div style="flex:1;text-align:center;padding:14px;background:var(--navy);border-radius:10px;">
                    <div style="font-size:20px;font-weight:800;font-family:'Outfit',sans-serif;color:var(--ice);">@pendingServices</div>
                    <div style="font-size:12px;color:var(--muted);">Pending Services</div>
                </div>
                <div style="flex:1;text-align:center;padding:14px;background:var(--navy);border-radius:10px;">
                    <div style="font-size:20px;font-weight:800;font-family:'Outfit',sans-serif;color:var(--success);">@totalSuppliers</div>
                    <div style="font-size:12px;color:var(--muted);">Suppliers</div>
                </div>
            </div>
        </div>

        <!-- Reactivate shortcut -->
        <div class="fms-card">
            <div style="display:flex;align-items:center;gap:14px;">
                <div class="stat-icon red" style="border-radius:10px;flex-shrink:0;"><i class="fa-solid fa-user-slash"></i></div>
                <div style="flex:1;">
                    <div style="font-family:'Outfit',sans-serif;font-weight:600;font-size:14px;">Deactivated Accounts</div>
                    <div style="font-size:12.5px;color:var(--muted);">Review and reactivate users</div>
                </div>
                <a asp-controller="Account" asp-action="ReactivateAccount" class="btn-fms btn-ghost-fms btn-sm-fms">
                    Manage
                </a>
            </div>
        </div>
    </div>
</div>
