@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
    ViewData["ActivePage"] = "Dashboard";

    /* These would normally come from ViewBag / ViewModel */
    var totalEmployees  = ViewBag.TotalEmployees  ?? 0;
    var totalCustomers  = ViewBag.TotalCustomers  ?? 0;
    var totalFridges    = ViewBag.TotalFridges    ?? 0;
    var allocatedFridges= ViewBag.AllocatedFridges?? 0;
    var totalSuppliers  = ViewBag.TotalSuppliers  ?? 0;
    var openFaults      = ViewBag.OpenFaults      ?? 0;
    var pendingServices = ViewBag.PendingServices ?? 0;
    var pendingOrders   = ViewBag.PendingOrders   ?? 0;
}

