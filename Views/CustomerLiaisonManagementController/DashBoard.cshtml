@* CustomerLiaisonManagementController/DashBoard.cshtml *@
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Customer Liaison Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    var totalCustomers  = ViewBag.TotalCustomers  ?? 0;
    var totalAllocations= ViewBag.TotalAllocations?? 0;
    var pendingRequests = ViewBag.PendingRequests ?? 0;
    var activeCustomers = ViewBag.ActiveCustomers ?? 0;
}

<!-- Stats Row -->
<div class="grid-4" style="margin-bottom:28px;">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fa-solid fa-store"></i></div>
        <div><div class="stat-value">@totalCustomers</div><div class="stat-label">Total Customers</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-circle-check"></i></div>
        <div><div class="stat-value">@activeCustomers</div><div class="stat-label">Active Customers</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon teal"><i class="fa-solid fa-link"></i></div>
        <div><div class="stat-value">@totalAllocations</div><div class="stat-label">Active Allocations</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fa-solid fa-clock"></i></div>
        <div><div class="stat-value">@pendingRequests</div><div class="stat-label">Pending Requests</div></div>
    </div>
</div>

<div class="grid-2">
    <!-- Quick Actions -->
    <div class="fms-card">
        <div class="fms-card-header"><div class="fms-card-title">Quick Actions</div></div>
        <div style="display:flex;flex-direction:column;gap:10px;">
            @{
                var actions = new[]{
                    ("fa-user-plus","Add New Customer","CustomerLiaisonManagementController","ManageCustomers","btn-primary-fms","Register a new spaza shop or shebeen"),
                    ("fa-link","Create Fridge Allocation","CustomerLiaisonManagementController","ManageAllocations","btn-ghost-fms","Allocate a fridge to a customer"),
                };
                foreach (var (icon, label, ctrl, action, btnClass, desc) in actions)
                {
                    <a asp-controller="@ctrl" asp-action="@action"
                       style="display:flex;align-items:center;gap:14px;padding:16px;
                              background:var(--navy);border:1px solid rgba(14,165,233,.1);border-radius:10px;
                              text-decoration:none;transition:var(--transition);"
                       onmouseover="this.style.borderColor='rgba(14,165,233,.35)'"
                       onmouseout="this.style.borderColor='rgba(14,165,233,.1)'">
                        <div class="stat-icon blue" style="width:42px;height:42px;border-radius:10px;flex-shrink:0;">
                            <i class="fa-solid @icon"></i>
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:14px;color:var(--white);">@label</div>
                            <div style="font-size:12.5px;color:var(--muted);margin-top:2px;">@desc</div>
                        </div>
                        <i class="fa-solid fa-chevron-right" style="color:var(--muted);margin-left:auto;"></i>
                    </a>
                }
            }
        </div>
    </div>

    <!-- Recent Customers -->
    <div class="fms-card">
        <div class="fms-card-header">
            <div class="fms-card-title">Recent Customers</div>
            <a asp-action="ManageCustomers" class="btn-fms btn-ghost-fms btn-sm-fms">View All</a>
        </div>
        @if (ViewBag.RecentCustomers != null)
        {
            <div style="display:flex;flex-direction:column;gap:10px;">
                @foreach (dynamic c in ViewBag.RecentCustomers)
                {
                    <div style="display:flex;align-items:center;gap:12px;padding:12px 0;
                                border-bottom:1px solid rgba(255,255,255,.04);">
                        <div style="width:34px;height:34px;border-radius:50%;
                                    background:linear-gradient(135deg,var(--navy-4),var(--ice));
                                    display:flex;align-items:center;justify-content:center;
                                    font-weight:700;font-size:12px;color:#fff;flex-shrink:0;">
                            @((c.BusinessName ?? "?")[0])
                        </div>
                        <div style="flex:1;">
                            <div style="font-weight:600;font-size:14px;">@c.BusinessName</div>
                            <div style="font-size:12px;color:var(--muted);">@c.ContactPerson</div>
                        </div>
                        <span class="fms-badge green" style="font-size:11px;">Active</span>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align:center;padding:28px 0;color:var(--muted);">No customers yet.</div>
        }
    </div>
</div>
